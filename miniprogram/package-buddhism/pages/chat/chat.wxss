@import "/app.wxss";
.container{padding:32rpx 24rpx;}
.page-title{display:block;font-size:34rpx;font-weight:bold;color:#3C2415;margin-bottom:24rpx;text-align:center;}
.master-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16rpx;margin-bottom:32rpx;}
.master-card{background:#FFF8E7;border:2rpx solid #E8D5A3;border-radius:20rpx;padding:24rpx;text-align:center;}
.master-card.active{border-color:#D4A017;background:rgba(212,160,23,0.06);box-shadow:0 0 0 2rpx rgba(212,160,23,0.2);}
.master-icon{display:block;font-size:44rpx;margin-bottom:8rpx;}
.master-name{display:block;font-size:30rpx;font-weight:bold;color:#3C2415;margin-bottom:4rpx;}
.master-school{display:block;font-size:22rpx;color:#D4A017;font-weight:bold;}
.master-desc{display:block;font-size:22rpx;color:#8B7355;margin-top:4rpx;}
.form-section{background:#FFF8E7;border-radius:24rpx;padding:28rpx 24rpx;margin-bottom:24rpx;}
.form-label{display:block;font-size:28rpx;color:#3C2415;font-weight:bold;margin-bottom:12rpx;}
.textarea-field{background:#FFFBF0;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:20rpx;font-size:28rpx;width:100%;height:180rpx;}
.submit-btn{background:linear-gradient(135deg,#D4A017,#F2BE45);text-align:center;padding:24rpx;border-radius:48rpx;font-size:32rpx;font-weight:bold;color:#3C2415;box-shadow:0 4rpx 16rpx rgba(212,160,23,0.3);}
