<view class="page container">
  <text class="page-title">选择一位禅师请益</text>
  <view class="master-grid">
    <view class="master-card {{selectedMaster===item.id?'active':''}}" wx:for="{{masters}}" wx:key="id" data-id="{{item.id}}" bindtap="onSelectMaster">
      <text class="master-icon">{{item.icon}}</text>
      <text class="master-name">{{item.name}}</text>
      <text class="master-school">{{item.school}}</text>
      <text class="master-desc">{{item.desc}}</text>
    </view>
  </view>
  <view class="form-section" wx:if="{{selectedMaster}}">
    <text class="form-label">您想请教什么？</text>
    <textarea class="textarea-field" placeholder="请输入您的人生疑惑..." value="{{question}}" bindinput="onQuestionInput" maxlength="300"/>
  </view>
  <view class="submit-btn" bindtap="onSubmit" wx:if="{{selectedMaster}}"><text>请益禅师</text></view>
</view>
