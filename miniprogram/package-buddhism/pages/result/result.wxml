<view class="page">
  <view class="master-header">
    <text class="master-icon-large">🙏</text>
    <text class="master-name">{{master.name}}</text>
    <text class="master-school">{{master.school}}</text>
  </view>
  <view class="card section">
    <text class="section-title">禅语</text>
    <text class="teaching-text">{{master.content}}</text>
  </view>
  <view class="citation-card">
    <text class="citation-label">经典引用</text>
    <text class="citation-text">{{master.citation}}</text>
  </view>
  <view class="card section">
    <text class="section-title">实修建议</text>
    <text class="teaching-text">{{master.practice}}</text>
  </view>
  <view class="action-row"><view class="btn-save" bindtap="onSave"><text>{{saved?'已保存':'保存记录'}}</text></view><view class="btn-retry" bindtap="onRetry"><text>继续请益</text></view></view>
  <view class="disclaimer">传统文化学习工具 · 弘扬国学经典智慧</view>
</view>
