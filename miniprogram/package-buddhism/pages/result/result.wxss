@import "/app.wxss";
.page{padding:24rpx;padding-bottom:120rpx;background:#FFFBF0;min-height:100vh;}
.master-header{display:flex;flex-direction:column;align-items:center;padding:40rpx 0 32rpx;}
.master-icon-large{font-size:72rpx;margin-bottom:12rpx;}
.master-name{font-size:40rpx;font-weight:bold;color:#3C2415;}
.master-school{font-size:26rpx;color:#D4A017;font-weight:bold;margin-top:8rpx;}
.section{background:#FFF8E7;border-radius:20rpx;padding:28rpx;margin-bottom:20rpx;border-left:8rpx solid #D4A017;}
.section-title{display:block;font-size:30rpx;font-weight:bold;color:#3C2415;margin-bottom:16rpx;}
.teaching-text{font-size:28rpx;color:#3C2415;line-height:2;}
.citation-card{background:rgba(212,160,23,0.08);border:2rpx solid rgba(212,160,23,0.2);border-radius:16rpx;padding:24rpx;margin-bottom:20rpx;}
.citation-label{display:block;font-size:24rpx;color:#D4A017;font-weight:bold;margin-bottom:8rpx;}
.citation-text{font-size:24rpx;color:#8B7355;font-style:italic;}
.action-row{display:flex;gap:24rpx;margin-top:32rpx;}
.btn-save{flex:1;background:linear-gradient(135deg,#D4A017,#F2BE45);color:#3C2415;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;font-weight:bold;}
.btn-retry{flex:1;background:#FFF8E7;border:2rpx solid #E8D5A3;color:#8B7355;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;}
.disclaimer{text-align:center;color:#BBA88A;font-size:22rpx;margin-top:24rpx;}
