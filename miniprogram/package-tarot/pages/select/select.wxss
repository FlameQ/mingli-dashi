@import "/app.wxss";
.container{padding:32rpx 24rpx;}
.page-title{display:block;font-size:34rpx;font-weight:bold;color:#3C2415;margin-bottom:24rpx;}
.spread-grid{display:flex;flex-direction:column;gap:16rpx;margin-bottom:32rpx;}
.spread-card{background:#FFF8E7;border:2rpx solid #E8D5A3;border-radius:20rpx;padding:24rpx;display:flex;align-items:center;gap:20rpx;}
.spread-card.active{border-color:#7B68AE;background:rgba(123,104,174,0.06);}
.spread-name{font-size:30rpx;font-weight:bold;color:#3C2415;min-width:160rpx;}
.spread-count{font-size:24rpx;color:#7B68AE;background:rgba(123,104,174,0.1);padding:4rpx 12rpx;border-radius:12rpx;}
.spread-desc{font-size:24rpx;color:#8B7355;flex:1;text-align:right;}
.form-section{background:#FFF8E7;border-radius:24rpx;padding:28rpx 24rpx;margin-bottom:24rpx;}
.form-label{display:block;font-size:28rpx;color:#3C2415;font-weight:bold;margin-bottom:12rpx;}
.textarea-field{background:#FFFBF0;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:20rpx;font-size:28rpx;width:100%;height:160rpx;}
.submit-btn{background:linear-gradient(135deg,#7B68AE,#9B8FD4);text-align:center;padding:24rpx;border-radius:48rpx;font-size:32rpx;font-weight:bold;color:#FFF;box-shadow:0 4rpx 16rpx rgba(123,104,174,0.3);}
