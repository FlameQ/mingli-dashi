<view class="page">
  <view class="cards-scroll">
    <view class="tarot-card {{item.isReversed?'reversed':''}}" wx:for="{{cards}}" wx:key="position">
      <text class="card-position">{{item.position}}</text>
      <view class="card-face"><text class="card-name">{{item.name}}</text></view>
      <text class="card-dir">{{item.isReversed?'逆位':'正位'}}</text>
    </view>
  </view>
  <view class="card section"><text class="section-title">综合解读</text><text class="reading-text">{{reading}}</text></view>
  <view class="action-row"><view class="btn-save" bindtap="onSave"><text>{{saved?'已保存':'保存记录'}}</text></view><view class="btn-retry" bindtap="onRetry"><text>重新抽牌</text></view></view>
  <view class="disclaimer">传统文化学习工具 · 弘扬国学经典智慧</view>
</view>
