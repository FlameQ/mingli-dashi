@import "/app.wxss";
.page { padding: 24rpx; padding-bottom: 120rpx; background: #FFFBF0; min-height: 100vh; }
.header-card { background: linear-gradient(135deg, #D4A017, #F2BE45); border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; text-align: center; }
.dun-type { display: block; font-size: 40rpx; font-weight: bold; color: #3C2415; }
.query-type { display: block; font-size: 24rpx; color: #8B7355; margin-top: 8rpx; }
.palace-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8rpx; margin-bottom: 24rpx; }
.palace-cell { background: #FFF8E7; border: 2rpx solid #E8D5A3; border-radius: 12rpx; padding: 16rpx 8rpx; text-align: center; }
.palace-pos { display: block; font-size: 20rpx; color: #8B7355; }
.palace-star { display: block; font-size: 24rpx; font-weight: bold; color: #AA2116; }
.palace-door { display: block; font-size: 22rpx; color: #3C2415; }
.palace-god { display: block; font-size: 20rpx; color: #D4A017; }
.section { background: #FFF8E7; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: bold; color: #3C2415; margin-bottom: 16rpx; border-left: 6rpx solid #D4A017; padding-left: 16rpx; }
.reading-text { font-size: 28rpx; color: #3C2415; line-height: 1.8; }
.action-row { display: flex; gap: 24rpx; margin-top: 32rpx; }
.btn-save { flex: 1; background: linear-gradient(135deg, #AA2116, #C93756); color: #FFF; text-align: center; padding: 20rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: bold; }
.btn-retry { flex: 1; background: #FFF8E7; border: 2rpx solid #E8D5A3; color: #8B7355; text-align: center; padding: 20rpx; border-radius: 40rpx; font-size: 28rpx; }
.disclaimer { text-align: center; color: #BBA88A; font-size: 22rpx; margin-top: 24rpx; }
