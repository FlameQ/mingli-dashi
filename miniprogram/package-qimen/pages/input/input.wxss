@import "/app.wxss";
.container { padding: 32rpx 24rpx; }
.form-section { background: #FFF8E7; border-radius: 24rpx; padding: 32rpx 24rpx; }
.form-title { display: block; font-size: 30rpx; font-weight: bold; color: #3C2415; margin-bottom: 20rpx; }
.type-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 32rpx; }
.type-card { width: calc(33% - 12rpx); padding: 20rpx 12rpx; background: #FFFBF0; border: 2rpx solid #E8D5A3; border-radius: 16rpx; text-align: center; }
.type-card.active { border-color: #AA2116; background: rgba(170,33,22,0.05); }
.type-icon { display: block; font-size: 36rpx; margin-bottom: 8rpx; }
.type-name { display: block; font-size: 24rpx; color: #3C2415; }
.form-item { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 28rpx; color: #3C2415; font-weight: bold; margin-bottom: 12rpx; }
.input-field { background: #FFFBF0; border: 2rpx solid #E8D5A3; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; }
.textarea-field { background: #FFFBF0; border: 2rpx solid #E8D5A3; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; width: 100%; height: 160rpx; }
.submit-btn { margin-top: 40rpx; background: linear-gradient(135deg, #D4A017, #F2BE45); text-align: center; padding: 24rpx; border-radius: 48rpx; font-size: 32rpx; font-weight: bold; color: #3C2415; box-shadow: 0 4rpx 16rpx rgba(212,160,23,0.3); }
