/* ========================================
   命理大师 - 水墨禅意配色方案
   Ink Wash Zen Theme
   ======================================== */

/* 页面背景 */
page {
  --bg-page: #1A1A2E;
  --bg-card: #252540;
  --bg-card-alt: #2D2D44;
  --bg-input: #2D2D44;
  --bg-surface: #1E1E36;

  /* 品牌色 - 天青 Celadon */
  --color-primary: #88ADA6;
  --color-primary-light: #A4D8D8;
  --color-secondary: #C9B98A;
  --color-secondary-light: #D4C9A0;

  /* 文本色 */
  --text-primary: #F0EDE0;
  --text-secondary: #A0A0B8;
  --text-placeholder: #666680;

  /* 功能色 */
  --color-accent: #88ADA6;
  --color-warning: #C9B98A;
  --color-success: #7BA98F;
  --color-border: #3A3A55;
  --color-border-dark: #4A4A66;

  /* 渐变 */
  --gradient-warm: linear-gradient(135deg, #1A1A2E 0%, #252540 50%, #2D2D44 100%);
  --gradient-card: linear-gradient(135deg, #252540 0%, #2D2D44 100%);
  --gradient-hero: linear-gradient(180deg, #252540 0%, #1A1A2E 100%);
  --gradient-primary: linear-gradient(135deg, #88ADA6 0%, #6B9490 100%);
  --gradient-secondary: linear-gradient(135deg, #C9B98A 0%, #B8A876 100%);

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* 字号 */
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-xxl: 48rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.25);
  --shadow-glow: 0 0 20rpx rgba(136, 173, 166, 0.15);
}
