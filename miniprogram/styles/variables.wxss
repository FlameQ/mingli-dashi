/* ========================================
   命理大师 - 宣纸水墨主题
   Rice Paper & Ink Theme
   ======================================== */

page {
  --bg-page: #F7F3EC;
  --bg-card: #FFFCF5;
  --bg-card-alt: #F5F0E8;
  --bg-input: #F0EBE1;
  --bg-surface: #FBF8F1;

  /* 品牌色 - 青瓷 Jade */
  --color-primary: #4A7C8A;
  --color-primary-light: #6A9CA8;
  --color-secondary: #B8952A;
  --color-secondary-light: #CCAA44;

  /* 文本色 */
  --text-primary: #2D2D2D;
  --text-secondary: #7A7A7A;
  --text-placeholder: #AAAAAA;

  /* 功能色 */
  --color-accent: #4A7C8A;
  --color-warning: #B8952A;
  --color-success: #5B8A72;
  --color-border: #E5DFD3;
  --color-border-dark: #D0C8B8;

  /* 渐变 */
  --gradient-warm: linear-gradient(135deg, #F7F3EC 0%, #FFFCF5 50%, #F5F0E8 100%);
  --gradient-card: linear-gradient(135deg, #FFFCF5 0%, #FBF8F1 100%);
  --gradient-hero: linear-gradient(180deg, #F5F0E8 0%, #F7F3EC 100%);
  --gradient-primary: linear-gradient(135deg, #4A7C8A 0%, #3A6472 100%);
  --gradient-secondary: linear-gradient(135deg, #B8952A 0%, #9A7D22 100%);

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* 字号 */
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-xxl: 48rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  --shadow-glow: 0 0 20rpx rgba(74, 124, 138, 0.1);
}
