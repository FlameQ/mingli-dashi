/* ========================================
   命理大师 - 雅致主题（无渐变）
   Elegant Flat Theme
   ======================================== */

page {
  --bg-page: #F0ECE5;
  --bg-card: #FFFFFF;
  --bg-card-alt: #F7F4EF;
  --bg-input: #F5F2ED;
  --bg-surface: #FAFAF8;

  --color-primary: #8C7A63;
  --color-primary-light: #A08E78;
  --color-secondary: #B8860B;
  --color-secondary-light: #CCAA44;

  --text-primary: #1C1917;
  --text-secondary: #7D7568;
  --text-placeholder: #A09888;

  --color-accent: #C4A265;
  --color-warning: #C4965A;
  --color-success: #5A7A6E;
  --color-border: #E3DDD5;
  --color-border-dark: #D4CFC6;

  --radius-sm: 8rpx; --radius-md: 16rpx; --radius-lg: 24rpx; --radius-xl: 32rpx;
  --space-xs: 8rpx; --space-sm: 16rpx; --space-md: 24rpx; --space-lg: 32rpx; --space-xl: 48rpx;
  --font-xs: 22rpx; --font-sm: 26rpx; --font-md: 30rpx; --font-lg: 34rpx; --font-xl: 40rpx; --font-xxl: 48rpx;

  --shadow-sm: 0 1rpx 4rpx rgba(28, 25, 23, 0.05);
  --shadow-md: 0 2rpx 12rpx rgba(28, 25, 23, 0.06);
  --shadow-lg: 0 4rpx 24rpx rgba(28, 25, 23, 0.08);
}
