.chinese-border {
  position: relative;
  border: 1rpx solid #E5DFD3;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FFFCF5;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.chinese-border::before,
.chinese-border::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #4A7C8A;
}

.chinese-border::before {
  top: 8rpx;
  left: 8rpx;
  border-right: none;
  border-bottom: none;
}

.chinese-border::after {
  bottom: 8rpx;
  right: 8rpx;
  border-left: none;
  border-top: none;
}

.scroll-container {
  background: #FFFCF5;
  border: 1rpx solid #E5DFD3;
  border-radius: 16rpx;
  padding: 32rpx;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.zen-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #E5DFD3, #4A7C8A, #E5DFD3, transparent);
  margin: 24rpx 0;
  opacity: 0.6;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in {
  animation: fadeIn 0.5s ease-out forwards;
}

.hexagram-symbol {
  font-family: serif;
  font-size: 80rpx;
  color: #4A7C8A;
}

.fortune-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.fortune-badge.excellent {
  background: rgba(74, 124, 138, 0.12);
  color: #4A7C8A;
  border: 1rpx solid rgba(74, 124, 138, 0.25);
}

.fortune-badge.good {
  background: rgba(91, 138, 114, 0.12);
  color: #5B8A72;
  border: 1rpx solid rgba(91, 138, 114, 0.25);
}

.fortune-badge.neutral {
  background: rgba(122, 122, 122, 0.12);
  color: #7A7A7A;
  border: 1rpx solid rgba(122, 122, 122, 0.25);
}

.fortune-badge.poor {
  background: rgba(184, 149, 42, 0.12);
  color: #B8952A;
  border: 1rpx solid rgba(184, 149, 42, 0.25);
}
