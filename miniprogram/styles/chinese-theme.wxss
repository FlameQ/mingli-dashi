/* ========================================
   命理大师 - 水墨禅意主题
   Ink Wash Zen Theme
   ======================================== */

/* Zen Border - minimal corners */
.chinese-border {
  position: relative;
  border: 2rpx solid #3A3A55;
  border-radius: 16rpx;
  overflow: hidden;
}

.chinese-border::before,
.chinese-border::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #88ADA6;
}

.chinese-border::before {
  top: 8rpx;
  left: 8rpx;
  border-right: none;
  border-bottom: none;
}

.chinese-border::after {
  bottom: 8rpx;
  right: 8rpx;
  border-left: none;
  border-top: none;
}

/* Scroll container - clean dark style */
.scroll-container {
  background: #252540;
  border: 1rpx solid #3A3A55;
  border-radius: 16rpx;
  padding: 32rpx;
  position: relative;
}

/* Zen Divider - thin line with subtle glow */
.zen-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #3A3A55, #88ADA6, #3A3A55, transparent);
  margin: 24rpx 0;
  opacity: 0.8;
}

/* Animations - minimal fade only */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in {
  animation: fadeIn 0.5s ease-out forwards;
}

/* Hexagram symbol style */
.hexagram-symbol {
  font-family: serif;
  font-size: 80rpx;
  color: #88ADA6;
  text-shadow: none;
}

/* Fortune badge */
.fortune-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.fortune-badge.excellent {
  background: rgba(136, 173, 166, 0.15);
  color: #88ADA6;
  border: 1rpx solid rgba(136, 173, 166, 0.3);
}

.fortune-badge.good {
  background: rgba(123, 169, 143, 0.15);
  color: #7BA98F;
  border: 1rpx solid rgba(123, 169, 143, 0.3);
}

.fortune-badge.neutral {
  background: rgba(160, 160, 184, 0.15);
  color: #A0A0B8;
  border: 1rpx solid rgba(160, 160, 184, 0.3);
}

.fortune-badge.poor {
  background: rgba(201, 185, 138, 0.15);
  color: #C9B98A;
  border: 1rpx solid rgba(201, 185, 138, 0.3);
}
