   ======================================== */

.chinese-border {
  position: relative; border: 1rpx solid #E8E0D0; border-radius: 16rpx;
  overflow: hidden; background: #FDFAF2; box-shadow: 0 4rpx 16rpx rgba(62, 39, 35, 0.04);
}
.chinese-border::before, .chinese-border::after {
  content: ''; position: absolute; width: 24rpx; height: 24rpx; border: 2rpx solid #C9A96E;
}
.chinese-border::before { top: 8rpx; left: 8rpx; border-right: none; border-bottom: none; }
.chinese-border::after { bottom: 8rpx; right: 8rpx; border-left: none; border-top: none; }

.scroll-container {
  background: #FDFAF2; border: 1rpx solid #E8E0D0; border-radius: 16rpx;
  padding: 32rpx; position: relative; box-shadow: 0 4rpx 16rpx rgba(62, 39, 35, 0.04);
}

.zen-divider { height: 1rpx; background: linear-gradient(90deg, transparent, #E8E0D0, #C9A96E, #E8E0D0, transparent); margin: 24rpx 0; opacity: 0.6; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(20rpx); } to { opacity: 1; transform: translateY(0); } }
.animate-fade-in { animation: fadeIn 0.5s ease-out forwards; }

.hexagram-symbol { font-family: serif; font-size: 80rpx; color: #C9A96E; }

.fortune-badge { display: inline-flex; align-items: center; padding: 4rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: bold; }
.fortune-badge.excellent { background: rgba(201, 169, 110, 0.12); color: #C9A96E; border: 1rpx solid rgba(201, 169, 110, 0.25); }
.fortune-badge.good { background: rgba(61, 107, 94, 0.12); color: #3D6B5E; border: 1rpx solid rgba(61, 107, 94, 0.25); }
.fortune-badge.neutral { background: rgba(125, 107, 93, 0.12); color: #7D6B5D; border: 1rpx solid rgba(125, 107, 93, 0.25); }
.fortune-badge.poor { background: rgba(196, 150, 90, 0.12); color: #C4965A; border: 1rpx solid rgba(196, 150, 90, 0.25); }
