@import "/app.wxss";
.page{padding:24rpx;padding-bottom:120rpx;background:#FFFBF0;min-height:100vh;}
.header-card{background:linear-gradient(135deg,#6B9E3C,#8BC34A);border-radius:24rpx;padding:32rpx;margin-bottom:24rpx;text-align:center;}
.header-title{font-size:34rpx;font-weight:bold;color:#FFF;}
.palace-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8rpx;margin-bottom:24rpx;}
.palace-cell{background:#FFF8E7;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:16rpx;text-align:center;}
.palace-pos{display:block;font-size:20rpx;color:#8B7355;}
.palace-star{display:block;font-size:32rpx;font-weight:bold;color:#6B9E3C;}
.section{background:#FFF8E7;border-radius:20rpx;padding:28rpx;margin-bottom:20rpx;}
.section-title{display:block;font-size:30rpx;font-weight:bold;color:#3C2415;margin-bottom:16rpx;border-left:6rpx solid #6B9E3C;padding-left:16rpx;}
.dir-row{display:flex;flex-wrap:wrap;align-items:center;gap:12rpx;margin-bottom:12rpx;}
.dir-label{font-size:24rpx;font-weight:bold;padding:4rpx 12rpx;border-radius:8rpx;}
.dir-label.good{background:rgba(107,158,60,0.15);color:#4A7A1A;}
.dir-label.bad{background:rgba(240,112,80,0.15);color:#D4503A;}
.dir-tag{font-size:22rpx;padding:4rpx 12rpx;border-radius:8rpx;}
.dir-tag.good{background:rgba(107,158,60,0.08);color:#6B9E3C;}
.dir-tag.bad{background:rgba(240,112,80,0.08);color:#F07050;}
.check-item{margin-bottom:16rpx;padding-bottom:16rpx;border-bottom:1rpx solid #F4EFE6;}
.check-item:last-child{border-bottom:none;}
.check-area{font-size:28rpx;font-weight:bold;color:#3C2415;margin-right:16rpx;}
.check-status{font-size:24rpx;padding:4rpx 12rpx;border-radius:8rpx;}
.check-status.good{background:rgba(107,158,60,0.15);color:#4A7A1A;}
.check-status.warn{background:rgba(240,112,80,0.15);color:#D4503A;}
.check-desc{display:block;font-size:24rpx;color:#8B7355;margin-top:8rpx;}
.reading-text{font-size:28rpx;color:#3C2415;line-height:1.8;}
.action-row{display:flex;gap:24rpx;margin-top:32rpx;}
.btn-save{flex:1;background:linear-gradient(135deg,#6B9E3C,#8BC34A);color:#FFF;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;font-weight:bold;}
.btn-retry{flex:1;background:#FFF8E7;border:2rpx solid #E8D5A3;color:#8B7355;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;}
.disclaimer{text-align:center;color:#BBA88A;font-size:22rpx;margin-top:24rpx;}
