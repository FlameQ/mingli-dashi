<view class="page">
  <view class="header-card"><text class="header-title">{{params.type}} · {{params.facing}}向</text></view>
  <view class="palace-grid">
    <view class="palace-cell" wx:for="{{flyingStars}}" wx:key="position">
      <text class="palace-pos">{{item.position}}</text>
      <text class="palace-star">{{item.star}}</text>
    </view>
  </view>
  <view class="card section">
    <text class="section-title">八宅方位</text>
    <view class="dir-row"><text class="dir-label good">吉方</text><text wx:for="{{luckyDirs}}" wx:key="name" class="dir-tag good">{{item.name}}·{{item.direction}}</text></view>
    <view class="dir-row"><text class="dir-label bad">凶方</text><text wx:for="{{unluckyDirs}}" wx:key="name" class="dir-tag bad">{{item.name}}·{{item.direction}}</text></view>
  </view>
  <view class="card section">
    <text class="section-title">区域检查</text>
    <view class="check-item" wx:for="{{shaQiChecks}}" wx:key="area">
      <text class="check-area">{{item.area}}</text>
      <text class="check-status {{item.status==='良好'?'good':'warn'}}">{{item.status}}</text>
      <text class="check-desc">{{item.desc}}</text>
    </view>
  </view>
  <view class="card section"><text class="section-title">布局建议</text><text class="reading-text">{{advice}}</text></view>
  <view class="action-row"><view class="btn-save" bindtap="onSave"><text>{{saved?'已保存':'保存记录'}}</text></view><view class="btn-retry" bindtap="onRetry"><text>重新分析</text></view></view>
  <view class="disclaimer">传统文化学习工具 · 弘扬国学经典智慧</view>
</view>
