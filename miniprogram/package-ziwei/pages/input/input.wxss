@import "/app.wxss";
.container{padding:32rpx 24rpx;}
.form-section{background:#FFF8E7;border-radius:24rpx;padding:32rpx 24rpx;}
.form-item{margin-bottom:28rpx;}
.form-label{display:block;font-size:28rpx;color:#3C2415;font-weight:bold;margin-bottom:12rpx;}
.input-field{background:#FFFBF0;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:20rpx;font-size:28rpx;}
.radio-group{display:flex;gap:32rpx;}
.radio-label{font-size:28rpx;display:flex;align-items:center;gap:8rpx;}
.picker-field{background:#FFFBF0;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:20rpx;font-size:28rpx;color:#3C2415;display:flex;justify-content:space-between;}
.submit-btn{margin-top:40rpx;background:linear-gradient(135deg,#C93756,#E85D7A);color:#FFF;text-align:center;padding:24rpx;border-radius:48rpx;font-size:32rpx;font-weight:bold;box-shadow:0 4rpx 16rpx rgba(201,55,86,0.3);}
