<view class="page container">
  <view class="form-section">
    <view class="form-item"><text class="form-label">姓名</text><input class="input-field" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput"/></view>
    <view class="form-item"><text class="form-label">性别</text><radio-group class="radio-group" bindchange="onGenderChange"><label class="radio-label"><radio value="男" checked="{{gender==='男'}}" color="#88ADA6"/>男</label><label class="radio-label"><radio value="女" checked="{{gender==='女'}}" color="#88ADA6"/>女</label></radio-group></view>
    <view class="form-item"><text class="form-label">出生日期</text><picker mode="date" value="{{birthDate}}" bindchange="onDateChange"><view class="picker-field">{{birthDate}} ›</view></picker></view>
    <view class="form-item"><text class="form-label">出生时辰</text><picker range="{{shichenOptions}}" value="{{birthHourIndex}}" bindchange="onHourChange"><view class="picker-field">{{shichenOptions[birthHourIndex]}} ›</view></picker></view>
  </view>
  <view class="submit-btn" bindtap="onSubmit"><text>排盘测算</text></view>
</view>
