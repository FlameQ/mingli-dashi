@import "/app.wxss";
.page{padding:24rpx;padding-bottom:120rpx;background:#FFFBF0;min-height:100vh;}
.header-card{background:linear-gradient(135deg,#C93756,#E85D7A);border-radius:24rpx;padding:32rpx;margin-bottom:24rpx;text-align:center;}
.header-title{font-size:34rpx;font-weight:bold;color:#FFF;}
.palace-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8rpx;margin-bottom:24rpx;}
.palace-cell{background:#FFF8E7;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:12rpx 8rpx;text-align:center;}
.palace-name{display:block;font-size:20rpx;color:#8B7355;margin-bottom:4rpx;}
.palace-stars{display:block;font-size:22rpx;color:#C93756;font-weight:bold;}
.section{background:#FFF8E7;border-radius:20rpx;padding:28rpx;margin-bottom:20rpx;}
.section-title{display:block;font-size:30rpx;font-weight:bold;color:#3C2415;margin-bottom:16rpx;border-left:6rpx solid #C93756;padding-left:16rpx;}
.reading-item{margin-bottom:20rpx;padding-bottom:20rpx;border-bottom:1rpx solid #E8D5A3;}
.reading-item:last-child{border-bottom:none;}
.reading-palace{display:block;font-size:28rpx;font-weight:bold;color:#C93756;margin-bottom:8rpx;}
.reading-desc{font-size:26rpx;color:#3C2415;line-height:1.7;}
.action-row{display:flex;gap:24rpx;margin-top:32rpx;}
.btn-save{flex:1;background:linear-gradient(135deg,#C93756,#E85D7A);color:#FFF;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;font-weight:bold;}
.btn-retry{flex:1;background:#FFF8E7;border:2rpx solid #E8D5A3;color:#8B7355;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;}
.disclaimer{text-align:center;color:#BBA88A;font-size:22rpx;margin-top:24rpx;}
