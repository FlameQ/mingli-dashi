<view class="page">
  <view class="header-card"><text class="header-title">命宫主星：{{mingGong}}</text></view>
  <view class="palace-grid">
    <view class="palace-cell" wx:for="{{palaces}}" wx:key="name">
      <text class="palace-name">{{item.name}}</text>
      <text class="palace-stars">{{item.stars.join(' ')}}</text>
    </view>
  </view>
  <view class="card section">
    <text class="section-title">重点宫位解读</text>
    <view class="reading-item" wx:for="{{keyReadings}}" wx:key="palace">
      <text class="reading-palace">{{item.palace}}</text>
      <text class="reading-desc">{{item.desc}}</text>
    </view>
  </view>
  <view class="action-row"><view class="btn-save" bindtap="onSave"><text>{{saved?'已保存':'保存记录'}}</text></view><view class="btn-retry" bindtap="onRetry"><text>重新测算</text></view></view>
  <view class="disclaimer">传统文化学习工具 · 弘扬国学经典智慧</view>
</view>
