@import "/app.wxss";
.page{padding:24rpx;padding-bottom:120rpx;background:#FFFBF0;min-height:100vh;}
.gua-header{display:flex;flex-direction:column;align-items:center;padding:32rpx;margin-bottom:24rpx;}
.gua-symbol{font-size:80rpx;color:#B36D61;}
.gua-name{font-size:36rpx;font-weight:bold;color:#3C2415;margin-top:8rpx;}
.yao-list{background:#FFF8E7;border-radius:20rpx;padding:24rpx;margin-bottom:24rpx;border:2rpx solid #E8D5A3;}
.yao-item{display:flex;align-items:center;justify-content:space-between;padding:16rpx 0;border-bottom:1rpx solid #F4EFE6;}
.yao-item:last-child{border-bottom:none;}
.yao-item.moving{background:rgba(179,109,97,0.08);}
.yao-label{font-size:24rpx;color:#8B7355;width:80rpx;}
.yao-line{font-family:monospace;font-size:28rpx;color:#3C2415;letter-spacing:8rpx;}
.yao-type{font-size:22rpx;color:#B36D61;width:80rpx;text-align:right;}
.section{background:#FFF8E7;border-radius:20rpx;padding:28rpx;margin-bottom:20rpx;}
.section-title{display:block;font-size:30rpx;font-weight:bold;color:#3C2415;margin-bottom:16rpx;border-left:6rpx solid #B36D61;padding-left:16rpx;}
.reading-text{font-size:28rpx;color:#3C2415;line-height:1.8;}
.action-row{display:flex;gap:24rpx;margin-top:32rpx;}
.btn-save{flex:1;background:linear-gradient(135deg,#B36D61,#D4918A);color:#FFF;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;font-weight:bold;}
.btn-retry{flex:1;background:#FFF8E7;border:2rpx solid #E8D5A3;color:#8B7355;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;}
.disclaimer{text-align:center;color:#BBA88A;font-size:22rpx;margin-top:24rpx;}
