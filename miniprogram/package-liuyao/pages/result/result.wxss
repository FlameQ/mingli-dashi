.page{min-height:100vh;background:#F7F2E7;padding:24rpx;padding-bottom:160rpx;}
.page,.page view,.page text{box-sizing:border-box;}

/* 卦名头部 */
.gua-header{display:flex;flex-direction:column;align-items:center;padding:32rpx 0 24rpx;}
.gua-palace-tag{font-size:20rpx;color:#C9A96E;background:rgba(201,169,110,0.1);padding:4rpx 16rpx;border-radius:12rpx;margin-bottom:12rpx;}
.gua-name{font-size:56rpx;font-weight:bold;color:#3E2723;letter-spacing:12rpx;}
.gua-num{font-size:22rpx;color:#A89888;margin-top:4rpx;}
.gua-desc{font-size:24rpx;color:#7D6B5D;margin-top:8rpx;font-style:italic;}

/* 上下卦 */
.trigram-row{display:flex;align-items:center;justify-content:center;gap:16rpx;margin-bottom:20rpx;}
.trigram-card{display:flex;flex-direction:column;align-items:center;background:#FDFAF2;border:1rpx solid #E8E0D0;border-radius:16rpx;padding:16rpx 28rpx;gap:4rpx;}
.tri-label{font-size:20rpx;color:#A89888;}
.tri-name{font-size:32rpx;font-weight:bold;color:#3E2723;}
.tri-nature{font-size:22rpx;color:#7D6B5D;}
.tri-element{font-size:20rpx;color:#C9A96E;background:rgba(201,169,110,0.1);padding:2rpx 12rpx;border-radius:8rpx;}
.tri-rel{display:flex;align-items:center;background:rgba(201,169,110,0.06);border:1rpx solid #E8E0D0;border-radius:20rpx;padding:8rpx 16rpx;font-size:22rpx;color:#C9A96E;font-weight:bold;}

/* Tab */
.tab-bar{display:flex;background:#FDFAF2;border-radius:16rpx;padding:6rpx;margin-bottom:20rpx;border:1rpx solid #E8E0D0;}
.tab-item{flex:1;text-align:center;padding:14rpx 0;font-size:24rpx;color:#7D6B5D;border-radius:12rpx;transition:all .2s;}
.tab-item.active{background:#C9A96E;color:#FFF;font-weight:bold;}

/* 六爻图 */
.yao-card{background:#FDFAF2;border-radius:20rpx;padding:20rpx 24rpx;border:1rpx solid #E8E0D0;margin-bottom:16rpx;}
.yao-row{display:flex;align-items:center;gap:12rpx;padding:12rpx 0;border-bottom:1rpx solid #F0EDE8;}
.yao-row:last-child{border-bottom:none;}
.yao-row.yao-moving{background:rgba(201,169,110,0.04);border-radius:8rpx;}
.yao-pos{font-size:22rpx;color:#A89888;width:32rpx;text-align:center;flex-shrink:0;}
.yao-line-area{display:flex;align-items:center;flex:1;gap:8rpx;justify-content:center;}
.yao-bar-inner{display:flex;align-items:center;justify-content:center;height:16rpx;}
.yao-bar-inner.yin{gap:10rpx;}
.yang-bar{width:200rpx;height:14rpx;background:#7D6B5D;border-radius:2rpx;}
.yao-bar-inner.moving .yang-bar{background:#C9A96E;height:16rpx;}
.yin-seg{width:92rpx;height:14rpx;background:#7D6B5D;border-radius:2rpx;}
.yao-bar-inner.moving .yin-seg{background:#C9A96E;height:16rpx;}
.yin-gap{width:10rpx;}
.yao-dot{width:16rpx;height:16rpx;border-radius:50%;flex-shrink:0;}
.yao-dot.dot-active{background:#C9A96E;}
.yao-type{font-size:20rpx;color:#A89888;margin-left:auto;flex-shrink:0;width:60rpx;text-align:right;}
.yao-tag{font-size:18rpx;color:#FFF;background:#C9A96E;padding:2rpx 8rpx;border-radius:6rpx;margin-left:6rpx;font-weight:bold;}
.yao-tag-res{background:#B8860B;}

/* 信息卡 */
.info-card{background:#FDFAF2;border-radius:16rpx;padding:20rpx;border:1rpx solid #E8E0D0;margin-bottom:12rpx;border-left:6rpx solid #C9A96E;}
.info-card-sub{border-left-color:#E8E0D0;}
.info-label{font-size:22rpx;color:#A89888;font-weight:500;margin-bottom:8rpx;display:block;}
.info-name{font-size:28rpx;font-weight:bold;color:#3E2723;}
.info-text{font-size:24rpx;color:#7D6B5D;line-height:1.7;margin-top:8rpx;}
.changed-flow{display:flex;align-items:center;gap:12rpx;margin-bottom:8rpx;}
.changed-from{font-size:26rpx;color:#7D6B5D;}
.changed-arrow{font-size:28rpx;color:#C9A96E;font-weight:bold;}
.changed-to{font-size:26rpx;font-weight:bold;color:#3E2723;}

/* 卦辞 */
.reading-card{background:rgba(201,169,110,0.06);border-radius:16rpx;padding:24rpx;margin-bottom:16rpx;text-align:center;}
.reading-label{font-size:22rpx;color:#A89888;display:block;margin-bottom:8rpx;}
.reading-text{font-size:28rpx;color:#3E2723;line-height:1.8;}

/* 六爻详解 */
.detail-list{display:flex;flex-direction:column;gap:12rpx;}
.detail-item{background:#FDFAF2;border-radius:16rpx;padding:20rpx;border:1rpx solid #E8E0D0;}
.detail-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx;padding-bottom:12rpx;border-bottom:1rpx solid #F0EDE8;}
.detail-pos-wrap{display:flex;align-items:center;gap:8rpx;}
.detail-pos{font-size:26rpx;font-weight:bold;color:#3E2723;}
.detail-tag{font-size:18rpx;color:#FFF;background:#C9A96E;padding:2rpx 8rpx;border-radius:6rpx;font-weight:bold;}
.detail-tag-res{background:#B8860B;}
.detail-moving{font-size:18rpx;color:#E53935;background:rgba(229,57,53,0.08);padding:2rpx 8rpx;border-radius:6rpx;font-weight:bold;}
.detail-badges{display:flex;gap:6rpx;}
.badge{font-size:20rpx;padding:4rpx 10rpx;border-radius:8rpx;}
.badge-liuqin{background:rgba(201,169,110,0.12);color:#C9A96E;font-weight:bold;}
.badge-zhi{background:#F5ECD7;color:#3E2723;}
.badge-element{background:rgba(201,169,110,0.06);color:#7D6B5D;}
.detail-body{display:flex;flex-direction:column;gap:8rpx;}
.detail-row{display:flex;justify-content:space-between;align-items:center;}
.detail-key{font-size:24rpx;color:#A89888;}
.detail-val{font-size:24rpx;color:#3E2723;}

/* 断卦分析 */
.analysis-card{background:#FDFAF2;border-radius:16rpx;padding:20rpx;border:1rpx solid #E8E0D0;margin-bottom:12rpx;}
.analysis-card-highlight{border-left:6rpx solid #C9A96E;}
.analysis-title{font-size:24rpx;font-weight:bold;color:#C9A96E;margin-bottom:12rpx;display:flex;align-items:center;gap:8rpx;}
.analysis-title::before{content:'';width:6rpx;height:20rpx;background:#C9A96E;border-radius:3rpx;}
.analysis-category{font-size:30rpx;font-weight:bold;color:#3E2723;margin-bottom:4rpx;display:block;}
.analysis-question{font-size:22rpx;color:#A89888;font-style:italic;display:block;}
.analysis-text{font-size:26rpx;color:#7D6B5D;line-height:1.8;}

/* 建议网格 */
.advice-grid{display:flex;flex-direction:column;gap:12rpx;margin-bottom:12rpx;}
.advice-item{background:#FDFAF2;border-radius:16rpx;padding:16rpx 20rpx;border:1rpx solid #E8E0D0;}
.advice-label{font-size:22rpx;font-weight:bold;color:#C9A96E;display:block;margin-bottom:6rpx;}
.advice-text{font-size:24rpx;color:#7D6B5D;line-height:1.7;}

/* 操作 */
.action-row{display:flex;gap:20rpx;margin-top:24rpx;}
.btn-save{flex:1;background:#C9A96E;color:#FFF;text-align:center;padding:22rpx;border-radius:48rpx;font-size:28rpx;font-weight:bold;}
.btn-retry{flex:1;background:#FDFAF2;border:1rpx solid #E8E0D0;color:#7D6B5D;text-align:center;padding:22rpx;border-radius:48rpx;font-size:28rpx;}
.disclaimer{text-align:center;color:#A89888;font-size:20rpx;margin-top:24rpx;}
