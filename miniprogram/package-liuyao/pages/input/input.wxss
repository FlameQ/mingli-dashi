@import "/app.wxss";
.container{padding:32rpx 24rpx;}
.form-section{background:#FFF8E7;border-radius:24rpx;padding:32rpx 24rpx;}
.form-item{margin-bottom:24rpx;}
.form-label{display:block;font-size:28rpx;color:#3C2415;font-weight:bold;margin-bottom:12rpx;}
.picker-field{background:#FFFBF0;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:20rpx;font-size:28rpx;display:flex;justify-content:space-between;}
.textarea-field{background:#FFFBF0;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:20rpx;font-size:28rpx;width:100%;height:140rpx;}
.number-row{display:flex;gap:16rpx;}
.num-input{flex:1;background:#FFFBF0;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:20rpx;font-size:28rpx;text-align:center;}
.coin-section{padding:20rpx 0;}
.coin-info{display:block;font-size:26rpx;color:#8B7355;margin-bottom:16rpx;}
.coin-btn{background:linear-gradient(135deg,#B36D61,#D4918A);color:#FFF;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;font-weight:bold;width:240rpx;margin:0 auto;}
.coin-history{margin-top:16rpx;display:flex;flex-direction:column;gap:8rpx;}
.coin-history text{font-size:24rpx;color:#8B7355;}
.submit-btn{margin-top:32rpx;background:linear-gradient(135deg,#B36D61,#D4918A);text-align:center;padding:24rpx;border-radius:48rpx;font-size:32rpx;font-weight:bold;color:#FFF;}
