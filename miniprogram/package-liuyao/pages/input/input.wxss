.page{min-height:100vh;background:#F7F2E7;padding:24rpx;padding-bottom:140rpx;}
.page,.page view,.page text{box-sizing:border-box;}

/* 方法选择 */
.method-grid{display:flex;gap:12rpx;margin-bottom:20rpx;}
.method-card{flex:1;background:#FDFAF2;border:2rpx solid #E8E0D0;border-radius:16rpx;padding:20rpx 12rpx;text-align:center;transition:all .2s;}
.method-card.active{border-color:#C9A96E;background:rgba(201,169,110,0.06);}
.method-icon{display:block;font-size:36rpx;margin-bottom:6rpx;}
.method-name{display:block;font-size:26rpx;font-weight:bold;color:#3E2723;margin-bottom:4rpx;}
.method-desc{display:block;font-size:20rpx;color:#A89888;}

/* 表单 */
.form-section{background:#FDFAF2;border-radius:20rpx;padding:24rpx;border:1rpx solid #E8E0D0;margin-bottom:20rpx;}
.form-title{display:block;font-size:28rpx;font-weight:bold;color:#3E2723;margin-bottom:12rpx;}
.textarea-field{background:#F5ECD7;border:2rpx solid #E8E0D0;border-radius:12rpx;padding:20rpx;font-size:28rpx;color:#3E2723;width:100%;height:140rpx;}
.char-count{display:block;text-align:right;font-size:20rpx;color:#A89888;margin-top:8rpx;}
.form-label{display:block;font-size:26rpx;color:#7D6B5D;margin-bottom:12rpx;}

/* 铜钱 */
.coin-section{background:#FDFAF2;border-radius:20rpx;padding:24rpx;border:1rpx solid #E8E0D0;margin-bottom:20rpx;}
.coin-progress{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx;}
.coin-progress-text{font-size:26rpx;color:#7D6B5D;font-weight:500;}
.coin-progress-dots{display:flex;gap:12rpx;}
.coin-dot{width:16rpx;height:16rpx;border-radius:50%;background:#E8E0D0;transition:background .3s;}
.coin-dot.done{background:#C9A96E;}

.coin-area{display:flex;flex-direction:column;align-items:center;}
.coins-row{display:flex;gap:40rpx;justify-content:center;margin-bottom:16rpx;}
.coin-wrap{display:flex;flex-direction:column;align-items:center;}
.coin{width:96rpx;height:96rpx;border-radius:50%;border:4rpx solid #C9A96E;background:#F5EDE0;display:flex;align-items:center;justify-content:center;box-shadow:0 4rpx 16rpx rgba(74,55,40,0.15),inset 0 2rpx 4rpx rgba(255,255,255,0.6);transition:all .3s;}
.coin-heads{background:#EEDDB8;border-color:#B8860B;}
.coin-tails{background:#D8CDB8;border-color:#8A7A5A;}
.coin-text{font-size:30rpx;font-weight:bold;color:#5A4A30;}
.coin-unknown{color:#B8A890;}
.coin-hint{font-size:20rpx;color:#A89888;margin-bottom:16rpx;}

@keyframes coinFlip{
  0%{transform:perspective(400rpx) translateY(0) rotateX(0deg) scale(1);}
  15%{transform:perspective(400rpx) translateY(-40rpx) rotateX(180deg) scale(1.1);}
  35%{transform:perspective(400rpx) translateY(-30rpx) rotateX(540deg) scale(1.08);}
  55%{transform:perspective(400rpx) translateY(-15rpx) rotateX(900deg) scale(1.04);}
  75%{transform:perspective(400rpx) translateY(-5rpx) rotateX(1260deg) scale(1);}
  100%{transform:perspective(400rpx) translateY(0) rotateX(1440deg) scale(1);}
}
.coin-flip{animation:coinFlip 1.2s cubic-bezier(.25,.46,.45,.94);}

.coin-toss-btn{width:280rpx;padding:18rpx 0;text-align:center;background:#C9A96E;color:#FFF;border-radius:48rpx;font-size:28rpx;font-weight:bold;box-shadow:0 4rpx 16rpx rgba(201,169,110,0.3);}
.coin-toss-btn.disabled{background:#C9C1B5;box-shadow:none;}

/* 已成爻 */
.coin-lines-built{margin-top:16rpx;background:#F5ECD7;border-radius:12rpx;padding:16rpx 20rpx;}
.coin-built-line{display:flex;align-items:center;gap:12rpx;padding:8rpx 0;}
.coin-built-num{font-size:22rpx;color:#A89888;width:32rpx;text-align:center;flex-shrink:0;}
.coin-built-type{font-size:20rpx;color:#A89888;margin-left:auto;flex-shrink:0;}
.coin-built-type.moving-type{color:#C9A96E;font-weight:bold;}

.yao-bar{display:flex;align-items:center;flex:1;gap:8rpx;justify-content:center;overflow:hidden;}
.yao-bar-inner{display:flex;align-items:center;justify-content:center;height:16rpx;}
.yao-bar-inner.yin{justify-content:center;gap:10rpx;}
.yang-line{width:140rpx;height:12rpx;background:#7D6B5D;border-radius:2rpx;flex-shrink:0;}
.yao-bar-inner.moving .yang-line{background:#C9A96E;height:14rpx;}
.yin-left,.yin-right{width:64rpx;height:12rpx;background:#7D6B5D;border-radius:2rpx;flex-shrink:0;}
.yao-bar-inner.moving .yin-left,.yao-bar-inner.moving .yin-right{background:#C9A96E;height:14rpx;}
.yin-gap{width:10rpx;}
.yao-marker{width:16rpx;height:16rpx;border-radius:50%;flex-shrink:0;background:transparent;}
.yao-marker.marker-active{background:#C9A96E;}
.yao-marker.marker-hidden{background:transparent;}

.coin-reset{text-align:center;margin-top:12rpx;padding:10rpx;font-size:22rpx;color:#A89888;}

/* 时间 */
.time-section{margin-bottom:20rpx;}
.time-info-card{background:#FDFAF2;border-radius:20rpx;padding:28rpx;border:1rpx solid #E8E0D0;text-align:center;}
.time-icon{display:block;font-size:48rpx;color:#C9A96E;margin-bottom:8rpx;}
.time-text{display:block;font-size:30rpx;color:#3E2723;font-weight:bold;margin-bottom:8rpx;}
.time-hint{display:block;font-size:22rpx;color:#A89888;}

/* 数字 */
.number-section{background:#FDFAF2;border-radius:20rpx;padding:24rpx;border:1rpx solid #E8E0D0;margin-bottom:20rpx;}
.number-row{display:flex;gap:16rpx;}
.num-input{flex:1;background:#F5ECD7;border:2rpx solid #E8E0D0;border-radius:12rpx;padding:20rpx;font-size:28rpx;text-align:center;color:#3E2723;}
.error-text{display:block;font-size:22rpx;color:#E53935;margin-top:8rpx;}

/* 提交 */
.submit-btn{margin-top:24rpx;background:#C9A96E;text-align:center;padding:24rpx;border-radius:48rpx;font-size:32rpx;font-weight:bold;color:#FFF;box-shadow:0 0 20rpx rgba(201,169,110,0.15);}
.disclaimer{text-align:center;color:#A89888;font-size:20rpx;margin-top:24rpx;}
