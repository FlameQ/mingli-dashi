@import "styles/variables.wxss";
@import "styles/chinese-theme.wxss";

page {
  background-color: #F0ECE5;
  color: #1C1917;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, navigator { box-sizing: border-box; }

.container { padding: 24rpx; min-height: 100vh; }

.section-title {
  font-size: 34rpx; font-weight: bold; color: #1C1917;
  margin-bottom: 24rpx; padding-left: 16rpx; border-left: 4rpx solid #8C7A63;
}

.card {
  background: #FFFFFF; border-radius: 24rpx; padding: 32rpx;
  border: 1rpx solid #E3DDD5; box-shadow: 0 2rpx 12rpx rgba(28, 25, 23, 0.06);
}

.btn-primary {
  background: #8C7A63; color: #FFFFFF; border: none; border-radius: 48rpx;
  padding: 24rpx 48rpx; font-size: 32rpx; font-weight: bold; text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(140, 122, 99, 0.2);
}
.btn-primary::after { border: none; }

.btn-secondary {
  background: transparent; color: #8C7A63; border: 2rpx solid #8C7A63;
  border-radius: 48rpx; padding: 24rpx 48rpx; font-size: 32rpx; font-weight: bold; text-align: center;
}

.input-field {
  background: #F5F2ED; border: 2rpx solid #E3DDD5; border-radius: 16rpx;
  padding: 20rpx 24rpx; font-size: 30rpx; color: #1C1917; width: 100%;
}
.input-field::placeholder { color: #A09888; }

.text-secondary { color: #7D7568; font-size: 26rpx; }

.disclaimer {
  text-align: center; color: #A09888; font-size: 22rpx;
  padding: 32rpx 0; margin-top: 24rpx; border-top: 1rpx solid #E3DDD5;
}
