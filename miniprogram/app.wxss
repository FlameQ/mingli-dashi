@import "styles/variables.wxss";
@import "styles/chinese-theme.wxss";

page {
  background-color: #F3F1ED;
  color: #1A1714;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, navigator { box-sizing: border-box; }

.container { padding: 24rpx; min-height: 100vh; }

.section-title {
  font-size: 34rpx; font-weight: bold; color: #1A1714;
  margin-bottom: 24rpx; padding-left: 16rpx; border-left: 4rpx solid #4A3728;
}

.card {
  background: #FFFFFF; border-radius: 24rpx; padding: 32rpx;
  border: 1rpx solid #DDD7CD; box-shadow: 0 2rpx 16rpx rgba(30, 25, 20, 0.08);
}

.btn-primary {
  background: #4A3728; color: #FFFFFF; border: none; border-radius: 48rpx;
  padding: 24rpx 48rpx; font-size: 32rpx; font-weight: bold; text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(74, 55, 40, 0.25);
}
.btn-primary::after { border: none; }

.btn-secondary {
  background: transparent; color: #4A3728; border: 2rpx solid #4A3728;
  border-radius: 48rpx; padding: 24rpx 48rpx; font-size: 32rpx; font-weight: bold; text-align: center;
}

.input-field {
  background: #F5F2ED; border: 2rpx solid #DDD7CD; border-radius: 16rpx;
  padding: 20rpx 24rpx; font-size: 30rpx; color: #1A1714; width: 100%;
}
.input-field::placeholder { color: #9A9088; }

.text-secondary { color: #7A7068; font-size: 26rpx; }

.disclaimer {
  text-align: center; color: #9A9088; font-size: 22rpx;
  padding: 32rpx 0; margin-top: 24rpx; border-top: 1rpx solid #DDD7CD;
}
