@import "styles/variables.wxss";
@import "styles/chinese-theme.wxss";

page {
  background-color: #F7F3EC;
  color: #2D2D2D;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, navigator {
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2D2D2D;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #4A7C8A;
}

.card {
  background: #FFFCF5;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #E5DFD3;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  background: linear-gradient(135deg, #4A7C8A 0%, #3A6472 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 32rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(74, 124, 138, 0.2);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: transparent;
  color: #4A7C8A;
  border: 2rpx solid #4A7C8A;
  border-radius: 32rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
}

.input-field {
  background: #F0EBE1;
  border: 2rpx solid #E5DFD3;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #2D2D2D;
  width: 100%;
}

.input-field::placeholder {
  color: #AAAAAA;
}

.text-secondary {
  color: #7A7A7A;
  font-size: 26rpx;
}

.disclaimer {
  text-align: center;
  color: #AAAAAA;
  font-size: 22rpx;
  padding: 32rpx 0;
  margin-top: 24rpx;
  border-top: 1rpx solid #E5DFD3;
}
