@import "styles/variables.wxss";
@import "styles/chinese-theme.wxss";

page {
  background-color: #F4F1EC;
  color: #2D2D2D;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, navigator {
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2D2D2D;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #3D6B5E;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #E5E0D8;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  background: #3D6B5E;
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(61, 107, 94, 0.2);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: transparent;
  color: #3D6B5E;
  border: 2rpx solid #3D6B5E;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.input-field {
  background: #F8F6F2;
  border: 2rpx solid #E5E0D8;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #2D2D2D;
  width: 100%;
}

.input-field::placeholder {
  color: #BBBBBB;
}

.text-secondary {
  color: #888888;
  font-size: 26rpx;
}

.disclaimer {
  text-align: center;
  color: #BBBBBB;
  font-size: 22rpx;
  padding: 32rpx 0;
  margin-top: 24rpx;
  border-top: 1rpx solid #E5E0D8;
}
