@import "styles/variables.wxss";
@import "styles/chinese-theme.wxss";

page {
  background-color: #1A1A2E;
  color: #F0EDE0;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, navigator {
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #F0EDE0;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #88ADA6;
}

.card {
  background: rgba(37, 37, 64, 0.7);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
}

.btn-primary {
  background: linear-gradient(135deg, #88ADA6 0%, #6B9490 100%);
  color: #1A1A2E;
  border: none;
  border-radius: 32rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(136, 173, 166, 0.2);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: transparent;
  color: #88ADA6;
  border: 2rpx solid rgba(136, 173, 166, 0.4);
  border-radius: 32rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
}

.input-field {
  background: rgba(45, 45, 68, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #F0EDE0;
  width: 100%;
}

.input-field::placeholder {
  color: #666680;
}

.text-secondary {
  color: #A0A0B8;
  font-size: 26rpx;
}

.disclaimer {
  text-align: center;
  color: #666680;
  font-size: 22rpx;
  padding: 32rpx 0;
  margin-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
