.tab-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #FFFFFF;
  display: flex; align-items: flex-start; justify-content: space-around;
  border-top: 1rpx solid #DDD7CD;
  padding: 12rpx 0 0;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  z-index: 999;
}
.tab-item {
  display: flex; flex-direction: column; align-items: center;
  justify-content: flex-start; flex: 1;
  position: relative;
}
.tab-icon-wrap {
  display: flex; flex-direction: column; align-items: center;
  justify-content: flex-start;
  position: relative;
  margin-bottom: 4rpx;
}
.tab-icon {
  font-size: 44rpx; line-height: 1;
  color: #B8B0A5;
  transition: color 0.25s;
}
.tab-icon-active {
  color: #4A3728;
}
.tab-text {
  font-size: 20rpx; color: #B8B0A5;
  transition: all 0.25s ease;
  line-height: 1.2;
}
.tab-indicator {
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: #4A3728;
  margin-top: 2rpx;
}
.tab-item.active .tab-text {
  color: #4A3728; font-weight: bold;
}
