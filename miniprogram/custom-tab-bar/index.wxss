.tab-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 110rpx;
  background: #FFFFFF;
  display: flex; align-items: center; justify-content: space-around;
  border-top: 1rpx solid #E3DDD5;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}
.tab-item {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; flex: 1; padding: 6rpx 0;
  position: relative;
}
.tab-icon-wrap {
  display: flex; flex-direction: column; align-items: center;
  margin-bottom: 4rpx; position: relative;
}
.tab-icon {
  font-size: 34rpx; color: #C4BEB5;
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.25s ease;
}
.tab-text {
  font-size: 20rpx; color: #C4BEB5;
  transition: all 0.25s ease;
}
.tab-indicator {
  position: absolute; bottom: -6rpx; left: 50%; transform: translateX(-50%);
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: #8C7A63;
}
.tab-item.active .tab-text {
  color: #8C7A63; font-weight: bold;
}
.tab-item.active .tab-icon {
  color: #8C7A63;
}
