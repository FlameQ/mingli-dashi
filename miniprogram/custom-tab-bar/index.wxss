.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: rgba(26, 26, 46, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 8rpx 0;
}

.tab-icon {
  font-size: 28rpx;
  margin-bottom: 6rpx;
  color: #666680;
  font-weight: bold;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-text {
  font-size: 20rpx;
  color: #666680;
  transition: color 0.2s;
}

.tab-item.active .tab-text {
  color: #88ADA6;
  font-weight: bold;
}

.tab-item.active .tab-icon {
  color: #88ADA6;
  background: rgba(136, 173, 166, 0.1);
  box-shadow: 0 0 12rpx rgba(136, 173, 166, 0.1);
}
