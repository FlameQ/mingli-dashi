.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #FFF8E7;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #E8D5A3;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 8rpx 0;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #8B7355;
}

.tab-item.active .tab-text {
  color: #AA2116;
  font-weight: bold;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}
