<view class="tab-bar">
  <view class="tab-item {{selected === index ? 'active' : ''}}"
        wx:for="{{list}}" wx:key="index"
        data-index="{{index}}" data-path="{{item.pagePath}}"
        bindtap="switchTab">
    <view class="tab-icon-wrap">
      <text class="tab-icon {{selected === index ? 'tab-icon-active' : ''}}">{{item.icon}}</text>
      <view class="tab-indicator" wx:if="{{selected === index}}"></view>
    </view>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
