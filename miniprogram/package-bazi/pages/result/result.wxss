.page{min-height:100vh;background:#F7F2E7;padding:24rpx;padding-bottom:120rpx;}
.header-card{background:linear-gradient(135deg,#FDFAF2,#F5F0E8);border-radius:24rpx;padding:36rpx 28rpx;margin-bottom:24rpx;text-align:center;border:1rpx solid #E8E0D0;}
.header-name{display:block;font-size:36rpx;font-weight:bold;color:#3E2723;letter-spacing:4rpx;margin-bottom:8rpx;}
.header-info{display:block;font-size:26rpx;color:#7D6B5D;margin-bottom:16rpx;}
.header-tags{display:flex;justify-content:center;gap:12rpx;}
.tag{font-size:22rpx;padding:4rpx 16rpx;border-radius:20rpx;background:rgba(201,169,110,0.08);color:#C9A96E;}
.card{background:#FDFAF2;border-radius:20rpx;padding:28rpx;margin-bottom:20rpx;border:1rpx solid #E8E0D0;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.04);}
.card-title{font-size:28rpx;font-weight:bold;color:#3E2723;margin-bottom:20rpx;padding-left:16rpx;border-left:4rpx solid #C9A96E;}
.card-text{font-size:26rpx;color:#7D6B5D;line-height:1.8;}
.pillars-row{display:flex;gap:16rpx;}
.pillar{flex:1;background:#F5ECD7;border-radius:16rpx;padding:20rpx 8rpx;text-align:center;border:1rpx solid #E8E0D0;}
.pillar-label{display:block;font-size:20rpx;color:#A89888;margin-bottom:8rpx;}
.pillar-gan{display:block;font-size:44rpx;font-weight:300;color:#C9A96E;}
.pillar-divider{width:40rpx;height:1rpx;background:#E8E0D0;margin:8rpx auto;}
.pillar-zhi{display:block;font-size:36rpx;color:#3E2723;}
.pillar-naying{display:block;font-size:18rpx;color:#A89888;margin-top:6rpx;}
.personality-trait{display:block;font-size:30rpx;font-weight:bold;color:#C9A96E;margin-bottom:12rpx;}
.trait-row{display:flex;gap:16rpx;margin-top:16rpx;}
.trait-item{flex:1;padding:16rpx;border-radius:12rpx;}
.trait-item.good{background:rgba(201,169,110,0.06);}
.trait-item.warn{background:rgba(196,150,90,0.06);}
.trait-label{display:block;font-size:22rpx;color:#A89888;margin-bottom:4rpx;}
.trait-value{display:block;font-size:24rpx;color:#3E2723;}
.wx-bars{display:flex;flex-direction:column;gap:12rpx;}
.wx-item{display:flex;align-items:center;gap:12rpx;}
.wx-name{font-size:24rpx;color:#7D6B5D;width:40rpx;text-align:center;}
.wx-bar-bg{flex:1;height:20rpx;background:#F5ECD7;border-radius:10rpx;overflow:hidden;}
.wx-bar{height:100%;border-radius:10rpx;background:#C9A96E;}
.wx-count{font-size:22rpx;color:#A89888;width:30rpx;text-align:center;}
.wx-tags{display:flex;gap:12rpx;margin-top:16rpx;}
.wx-tag{font-size:22rpx;padding:6rpx 16rpx;border-radius:16rpx;}
.wx-tag.xi{background:rgba(201,169,110,0.1);color:#C9A96E;}
.wx-tag.yong{background:rgba(196,150,90,0.1);color:#B8860B;}
.wx-tag.ji{background:rgba(136,136,136,0.1);color:#7D6B5D;}
.domain-list{display:flex;flex-direction:column;gap:24rpx;}
.domain-item{padding-bottom:20rpx;border-bottom:1rpx solid #E8E0D0;}
.domain-item:last-child{border-bottom:none;padding-bottom:0;}
.domain-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8rpx;}
.domain-title{font-size:28rpx;font-weight:bold;color:#3E2723;}
.domain-level{font-size:22rpx;padding:4rpx 14rpx;border-radius:12rpx;background:rgba(201,169,110,0.1);color:#C9A96E;}
.domain-reading{font-size:26rpx;color:#7D6B5D;line-height:1.8;display:block;}
.domain-advice{font-size:24rpx;color:#C9A96E;display:block;margin-top:8rpx;}
.dayun-scroll{white-space:nowrap;}
.dayun-item{display:inline-flex;flex-direction:column;align-items:center;width:200rpx;padding:20rpx 16rpx;background:#F5ECD7;border-radius:16rpx;border:1rpx solid #E8E0D0;margin-right:16rpx;vertical-align:top;}
.dayun-gz{font-size:32rpx;font-weight:300;color:#C9A96E;margin-bottom:4rpx;}
.dayun-age{font-size:20rpx;color:#A89888;margin-bottom:8rpx;}
.dayun-wx{font-size:22rpx;color:#3E2723;margin-bottom:4rpx;}
.dayun-reading{font-size:18rpx;color:#7D6B5D;white-space:normal;text-align:center;line-height:1.4;}
.lucky-grid{display:flex;flex-direction:column;gap:16rpx;}
.lucky-item{display:flex;align-items:center;padding:12rpx 16rpx;background:#F5ECD7;border-radius:12rpx;}
.lucky-label{font-size:24rpx;color:#7D6B5D;width:160rpx;flex-shrink:0;}
.lucky-value{font-size:24rpx;color:#3E2723;flex:1;}
.reading-section{margin-bottom:24rpx;padding-bottom:20rpx;border-bottom:1rpx solid #E8E0D0;}
.reading-section:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.reading-subtitle{display:block;font-size:26rpx;font-weight:bold;color:#C9A96E;margin-bottom:8rpx;}
.reading-content{font-size:26rpx;color:#7D6B5D;line-height:1.8;}
.action-row{display:flex;gap:24rpx;margin-top:32rpx;}
.btn-save{flex:1;background:#C9A96E;color:#FFFFFF;text-align:center;padding:22rpx;border-radius:48rpx;font-size:28rpx;font-weight:bold;}
.btn-retry{flex:1;background:#FDFAF2;border:1rpx solid #E8E0D0;color:#7D6B5D;text-align:center;padding:22rpx;border-radius:48rpx;font-size:28rpx;}
.disclaimer{text-align:center;color:#A89888;font-size:20rpx;margin-top:24rpx;}
