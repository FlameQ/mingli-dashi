<view class="page" wx:if="{{loaded}}">
  <!-- Header -->
  <view class="header-card">
    <text class="header-name">{{name || '八字排盘'}}</text>
    <text class="header-info">{{zodiac}} · {{dayMaster}}（{{dayMasterWx}}）· {{geju.name}}</text>
    <view class="header-date" wx:if="{{solarDateStr || lunarDateStr}}">
      <text class="header-solar" wx:if="{{solarDateStr}}">阳历：{{solarDateStr}}</text>
      <text class="header-lunar" wx:if="{{lunarDateStr}}">农历：{{lunarDateStr}}</text>
      <text class="header-lunar-gz" wx:if="{{lunarGanzhi}}">（{{lunarGanzhi}}年）</text>
    </view>
    <view class="header-tags">
      <text class="tag">{{strength.level}}</text>
      <text class="tag">喜{{xiyong.xi}}</text>
      <text class="tag">忌{{xiyong.ji}}</text>
    </view>
  </view>

  <!-- Four Pillars -->
  <view class="card">
    <view class="card-title">四柱八字</view>
    <view class="pillars-row">
      <view class="pillar" wx:for="{{[pillars.yearPillar, pillars.monthPillar, pillars.dayPillar, pillars.hourPillar]}}" wx:key="index">
        <text class="pillar-label">{{['年柱','月柱','日柱','时柱'][index]}}</text>
        <text class="pillar-gan">{{item[0]}}</text>
        <view class="pillar-divider"></view>
        <text class="pillar-zhi">{{item[1]}}</text>
        <text class="pillar-naying">{{[naying.year, naying.month, naying.day, naying.hour][index]}}</text>
      </view>
    </view>
  </view>

  <!-- 纳音五行详析 -->
  <view class="card" wx:if="{{nayingDetail.length > 0}}">
    <view class="card-title">纳音五行</view>
    <view class="naying-list">
      <view class="naying-item" wx:for="{{nayingDetail}}" wx:key="position">
        <view class="naying-header">
          <text class="naying-pos">{{item.position}}</text>
          <text class="naying-gz">{{item.ganzhi}}</text>
          <text class="naying-name">{{item.naying}}</text>
        </view>
        <text class="naying-meaning">{{item.meaning}}</text>
      </view>
    </view>
  </view>

  <!-- Personality -->
  <view class="card" wx:if="{{personality.trait}}">
    <view class="card-title">性格特质</view>
    <text class="personality-trait">{{personality.trait}}</text>
    <text class="card-text">{{personality.desc}}</text>
    <view class="trait-row">
      <view class="trait-item good">
        <text class="trait-label">优势</text>
        <text class="trait-value">{{personality.strength}}</text>
      </view>
      <view class="trait-item warn">
        <text class="trait-label">注意</text>
        <text class="trait-value">{{personality.weakness}}</text>
      </view>
    </view>
  </view>

  <!-- Five Elements -->
  <view class="card">
    <view class="card-title">五行分布</view>
    <view class="wx-bars">
      <view class="wx-item" wx:for="{{['金','木','水','火','土']}}" wx:key="*this">
        <text class="wx-name">{{item}}</text>
        <view class="wx-bar-bg">
          <view class="wx-bar" style="width: {{wuxingCount[item] * 14}}%;"></view>
        </view>
        <text class="wx-count">{{wuxingCount[item] || 0}}</text>
      </view>
    </view>
    <view class="wx-tags">
      <text class="wx-tag xi" wx:if="{{xiyong.xi}}">喜 {{xiyong.xi}}</text>
      <text class="wx-tag yong" wx:if="{{xiyong.yong}}">用 {{xiyong.yong}}</text>
      <text class="wx-tag ji" wx:if="{{xiyong.ji}}">忌 {{xiyong.ji}}</text>
    </view>
  </view>

  <!-- Xi Yong Explanation -->
  <view class="card">
    <view class="card-title">喜用神分析</view>
    <text class="card-text">{{xiyong.description}}</text>
  </view>

  <!-- 十神详批 -->
  <view class="card" wx:if="{{shishenDetail.details.length > 0}}">
    <view class="card-title">十神详批</view>
    <!-- 十神统计 -->
    <view class="ss-count-row" wx:if="{{shishenDetail.count}}">
      <view class="ss-count-item" wx:for="{{shishenDetail.count}}" wx:key="index">
        <text class="ss-count-name">{{item.key}}</text>
        <text class="ss-count-num">{{item.value}}</text>
      </view>
    </view>
    <!-- 逐柱详解 -->
    <view class="ss-detail-list">
      <view class="ss-detail-item" wx:for="{{shishenDetail.details}}" wx:key="index">
        <view class="ss-detail-header">
          <text class="ss-detail-pos">{{item.position}}</text>
          <text class="ss-detail-type">{{item.type}}</text>
          <text class="ss-detail-gz">{{item.ganzhi}}</text>
          <text class="ss-detail-name">{{item.shishen}}</text>
        </view>
        <text class="ss-detail-desc">{{item.desc}}</text>
        <view class="ss-detail-tags">
          <text class="ss-tag">事业：{{item.career}}</text>
          <text class="ss-tag">关系：{{item.relation}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 地支关系 -->
  <view class="card" wx:if="{{dizhiRelations.length > 0}}">
    <view class="card-title">地支关系</view>
    <view class="dz-relation-list">
      <view class="dz-relation-item {{item.level}}" wx:for="{{dizhiRelations}}" wx:key="index">
        <view class="dz-relation-header">
          <text class="dz-relation-type">{{item.type}}</text>
          <text class="dz-relation-desc">{{item.desc}}</text>
        </view>
        <text class="dz-relation-meaning">{{item.meaning}}</text>
      </view>
    </view>
  </view>

  <!-- 神煞系统 -->
  <view class="card" wx:if="{{shensha.length > 0}}">
    <view class="card-title">神煞</view>
    <view class="shensha-list">
      <view class="shensha-item {{item.type}}" wx:for="{{shensha}}" wx:key="name">
        <view class="shensha-header">
          <text class="shensha-icon">{{item.icon}}</text>
          <text class="shensha-name">{{item.name}}</text>
          <text class="shensha-type-badge">{{item.typeLabel}}</text>
        </view>
        <text class="shensha-desc">{{item.desc}}</text>
        <text class="shensha-meaning">{{item.meaning}}</text>
      </view>
    </view>
  </view>

  <!-- 十二长生 -->
  <view class="card" wx:if="{{changsheng.stages.length > 0}}">
    <view class="card-title">十二长生</view>
    <text class="card-subtitle">日支{{pillars.dayPillar[1]}}处于「{{changsheng.dayZhiStage}}」—— {{changsheng.dayZhiMeaning}}</text>
    <view class="cs-grid">
      <view class="cs-item {{item.isGood ? 'cs-good' : 'cs-normal'}} {{item.zhi === pillars.dayPillar[1] ? 'cs-current' : ''}}" wx:for="{{changsheng.stages}}" wx:key="stage">
        <text class="cs-stage">{{item.stage}}</text>
        <text class="cs-zhi">{{item.zhi}}</text>
      </view>
    </view>
  </view>

  <!-- 流年分析 -->
  <view class="card" wx:if="{{liunian.year}}">
    <view class="card-title">{{liunian.year}}年流年分析</view>
    <view class="liunian-header">
      <text class="liunian-gz">{{liunian.ganzhi}}</text>
      <text class="liunian-ss">十神：{{liunian.shishen}}</text>
      <text class="liunian-ts">太岁：{{liunian.taiSui}}</text>
    </view>
    <text class="card-text">{{liunian.reading}}</text>

    <!-- 逐月分析 -->
    <view class="card-title" style="margin-top: 20rpx;">逐月分析</view>
    <view class="month-grid">
      <view class="month-item {{item.level === '吉' ? 'month-good' : item.level === '注意' ? 'month-warn' : 'month-normal'}}" wx:for="{{liunian.monthFortune}}" wx:key="month">
        <text class="month-name">{{item.month}}</text>
        <text class="month-gz">{{item.ganzhi}}</text>
        <text class="month-level">{{item.level}}</text>
      </view>
    </view>
  </view>

  <!-- Life Domains -->
  <view class="card">
    <view class="card-title">人生格局</view>
    <view class="domain-list">
      <view class="domain-item" wx:for="{{[lifeDomains.career, lifeDomains.wealth, lifeDomains.love, lifeDomains.health]}}" wx:key="title">
        <view class="domain-header">
          <text class="domain-title">{{item.title}}</text>
          <text class="domain-level">{{item.level}}</text>
        </view>
        <text class="domain-reading">{{item.reading}}</text>
        <text class="domain-advice">建议：{{item.advice}}</text>
      </view>
    </view>
  </view>

  <!-- Dayun -->
  <view class="card" wx:if="{{dayunList.length > 0}}">
    <view class="card-title">大运走势</view>
    <scroll-view class="dayun-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="dayun-item" wx:for="{{dayunList}}" wx:key="ganzhi">
        <text class="dayun-gz">{{item.ganzhi}}</text>
        <text class="dayun-age">{{item.label}}</text>
        <text class="dayun-wx">{{item.wuxing}}</text>
        <text class="dayun-reading">{{item.reading}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- Lucky Elements -->
  <view class="card" wx:if="{{luckyElements.colors}}">
    <view class="card-title">幸运元素</view>
    <view class="lucky-grid">
      <view class="lucky-item">
        <text class="lucky-label">幸运颜色</text>
        <text class="lucky-value">{{luckyElements.colors}}</text>
      </view>
      <view class="lucky-item">
        <text class="lucky-label">有利方位</text>
        <text class="lucky-value">{{luckyElements.direction}}</text>
      </view>
      <view class="lucky-item">
        <text class="lucky-label">幸运数字</text>
        <text class="lucky-value">{{luckyElements.numbers}}</text>
      </view>
      <view class="lucky-item">
        <text class="lucky-label">旺运时节</text>
        <text class="lucky-value">{{luckyElements.season}}</text>
      </view>
      <view class="lucky-item">
        <text class="lucky-label">适业方向</text>
        <text class="lucky-value">{{luckyElements.industry}}</text>
      </view>
    </view>
  </view>

  <!-- Rich Readings -->
  <view class="card" wx:if="{{reading.sections}}">
    <view class="card-title">八字详批</view>
    <view class="reading-section" wx:for="{{reading.sections}}" wx:key="title">
      <text class="reading-subtitle">{{item.title}}</text>
      <text class="reading-content">{{item.content}}</text>
    </view>
  </view>

  <!-- Actions -->
  <view class="action-row">
    <view class="btn-save" bindtap="onSave">{{saved ? '已保存' : '保存记录'}}</view>
    <view class="btn-retry" bindtap="onRetry">重新测算</view>
  </view>
  <view class="disclaimer">传统文化学习工具 · 弘扬国学经典智慧</view>
</view>
