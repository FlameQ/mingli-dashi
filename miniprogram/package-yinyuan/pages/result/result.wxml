<view class="page">
  <view class="score-section">
    <view class="score-ring">
      <text class="score-num">{{score}}</text>
      <text class="score-unit">分</text>
    </view>
    <text class="score-label">缘分指数</text>
  </view>
  <view class="card section"><text class="section-title">缘分解读</text><text class="reading-text">{{reading}}</text></view>
  <view class="card section"><text class="section-title">月老建议</text><text class="reading-text">{{advice}}</text></view>
  <view class="action-row"><view class="btn-save" bindtap="onSave"><text>{{saved?'已保存':'保存记录'}}</text></view><view class="btn-retry" bindtap="onRetry"><text>重新测算</text></view></view>
  <view class="disclaimer">传统文化学习工具 · 弘扬国学经典智慧</view>
</view>
