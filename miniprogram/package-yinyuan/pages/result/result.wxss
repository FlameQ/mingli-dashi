@import "/app.wxss";
.page{padding:24rpx;padding-bottom:120rpx;background:#FFFBF0;min-height:100vh;}
.score-section{display:flex;flex-direction:column;align-items:center;padding:48rpx 0 32rpx;}
.score-ring{width:200rpx;height:200rpx;border-radius:50%;background:linear-gradient(135deg,#F07050,#F2BE45);display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 32rpx rgba(240,112,80,0.3);}
.score-num{font-size:64rpx;font-weight:bold;color:#FFF;}
.score-unit{font-size:28rpx;color:rgba(255,255,255,0.8);margin-left:4rpx;}
.score-label{font-size:28rpx;color:#8B7355;margin-top:16rpx;}
.section{background:#FFF8E7;border-radius:20rpx;padding:28rpx;margin-bottom:20rpx;}
.section-title{display:block;font-size:30rpx;font-weight:bold;color:#3C2415;margin-bottom:16rpx;border-left:6rpx solid #F07050;padding-left:16rpx;}
.reading-text{font-size:28rpx;color:#3C2415;line-height:1.8;}
.action-row{display:flex;gap:24rpx;margin-top:32rpx;}
.btn-save{flex:1;background:linear-gradient(135deg,#F07050,#F2BE45);color:#FFF;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;font-weight:bold;}
.btn-retry{flex:1;background:#FFF8E7;border:2rpx solid #E8D5A3;color:#8B7355;text-align:center;padding:20rpx;border-radius:40rpx;font-size:28rpx;}
.disclaimer{text-align:center;color:#BBA88A;font-size:22rpx;margin-top:24rpx;}
