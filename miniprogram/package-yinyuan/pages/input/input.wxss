.page{min-height:100vh;background:#1A1A2E;padding:32rpx 24rpx;padding-bottom:120rpx;}
.form-section{background:#252540;border-radius:24rpx;padding:32rpx 24rpx;border:1rpx solid #3A3A55;}
.form-item{margin-bottom:28rpx;}
.form-label{display:block;font-size:26rpx;color:#A0A0B8;margin-bottom:12rpx;}
.input-field{background:#2D2D44;border:2rpx solid #3A3A55;border-radius:12rpx;padding:20rpx;font-size:28rpx;color:#F0EDE0;}
.placeholder{color:#666680;}
.radio-group{display:flex;gap:32rpx;}
.radio-label{font-size:28rpx;color:#F0EDE0;display:flex;align-items:center;gap:8rpx;}
.picker-field{background:#2D2D44;border:2rpx solid #3A3A55;border-radius:12rpx;padding:20rpx;font-size:28rpx;color:#F0EDE0;display:flex;justify-content:space-between;}
.textarea-field{background:#2D2D44;border:2rpx solid #3A3A55;border-radius:12rpx;padding:20rpx;font-size:28rpx;color:#F0EDE0;width:100%;height:160rpx;}
.submit-btn{margin-top:40rpx;background:linear-gradient(135deg,#88ADA6,#6B9490);text-align:center;padding:24rpx;border-radius:48rpx;font-size:32rpx;font-weight:bold;color:#1A1A2E;box-shadow:0 0 20rpx rgba(136,173,166,0.15);}
.type-grid,.mode-grid{display:flex;flex-wrap:wrap;gap:12rpx;margin-bottom:24rpx;}
.type-card,.mode-card{min-width:calc(33% - 12rpx);padding:16rpx 12rpx;background:#2D2D44;border:2rpx solid #3A3A55;border-radius:16rpx;text-align:center;font-size:24rpx;color:#A0A0B8;}
.type-card.active,.mode-card.active{border-color:#88ADA6;background:rgba(136,173,166,0.08);color:#88ADA6;}
.type-icon,.mode-icon{display:block;font-size:32rpx;margin-bottom:6rpx;}
.type-name,.mode-name{display:block;font-size:24rpx;}
.form-title{display:block;font-size:28rpx;font-weight:bold;color:#F0EDE0;margin-bottom:16rpx;}
.num-input{flex:1;background:#2D2D44;border:2rpx solid #3A3A55;border-radius:12rpx;padding:20rpx;font-size:28rpx;text-align:center;color:#F0EDE0;}
.number-row{display:flex;gap:16rpx;}
.coin-section{padding:16rpx 0;}
.coin-info{display:block;font-size:24rpx;color:#A0A0B8;margin-bottom:12rpx;}
.coin-btn{background:linear-gradient(135deg,#88ADA6,#6B9490);color:#1A1A2E;text-align:center;padding:16rpx;border-radius:32rpx;font-size:26rpx;font-weight:bold;width:200rpx;margin:0 auto;}
.coin-history{margin-top:12rpx;display:flex;flex-direction:column;gap:6rpx;}
.coin-history text{font-size:22rpx;color:#A0A0B8;}
.spread-grid{display:flex;flex-direction:column;gap:12rpx;margin-bottom:24rpx;}
.spread-card{background:#252540;border:2rpx solid #3A3A55;border-radius:16rpx;padding:20rpx;display:flex;align-items:center;gap:16rpx;}
.spread-card.active{border-color:#88ADA6;background:rgba(136,173,166,0.06);}
.spread-name{font-size:28rpx;font-weight:bold;color:#F0EDE0;min-width:140rpx;}
.spread-count{font-size:22rpx;color:#88ADA6;background:rgba(136,173,166,0.1);padding:4rpx 10rpx;border-radius:8rpx;}
.spread-desc{font-size:22rpx;color:#A0A0B8;flex:1;text-align:right;}
.page-title{display:block;font-size:32rpx;font-weight:bold;color:#F0EDE0;margin-bottom:24rpx;text-align:center;}
