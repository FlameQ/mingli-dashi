@import "/app.wxss";
.container{padding:32rpx 24rpx;}
.mode-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16rpx;margin-bottom:32rpx;}
.mode-card{background:#FFF8E7;border:2rpx solid #E8D5A3;border-radius:20rpx;padding:28rpx 20rpx;text-align:center;}
.mode-card.active{border-color:#F07050;background:rgba(240,112,80,0.08);}
.mode-icon{display:block;font-size:44rpx;margin-bottom:8rpx;}
.mode-name{display:block;font-size:28rpx;font-weight:bold;color:#3C2415;margin-bottom:4rpx;}
.mode-desc{display:block;font-size:22rpx;color:#8B7355;}
.form-section{background:#FFF8E7;border-radius:24rpx;padding:32rpx 24rpx;margin-bottom:24rpx;}
.form-item{margin-bottom:24rpx;}
.form-label{display:block;font-size:28rpx;color:#3C2415;font-weight:bold;margin-bottom:12rpx;}
.picker-field{background:#FFFBF0;border:2rpx solid #E8D5A3;border-radius:12rpx;padding:20rpx;font-size:28rpx;display:flex;justify-content:space-between;}
.submit-btn{background:linear-gradient(135deg,#F07050,#F2BE45);text-align:center;padding:24rpx;border-radius:48rpx;font-size:32rpx;font-weight:bold;color:#FFF;box-shadow:0 4rpx 16rpx rgba(240,112,80,0.3);}
