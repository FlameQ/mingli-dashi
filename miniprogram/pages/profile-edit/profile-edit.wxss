.page { min-height: 100vh; background: #F7F2E7; padding: 32rpx 24rpx; padding-bottom: 120rpx; }
.form-section { background: #FDFAF2; border-radius: 24rpx; padding: 32rpx 24rpx; }
.form-item { margin-bottom: 32rpx; }
.form-item:last-child { margin-bottom: 0; }
.form-label { display: block; font-size: 26rpx; color: #7D6B5D; margin-bottom: 12rpx; }
.input-field { background: #F5ECD7; border: 2rpx solid rgba(58,58,85,0.5); border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #3E2723; }
.placeholder { color: #A89888; }
.radio-group { display: flex; gap: 40rpx; }
.radio-label { font-size: 28rpx; color: #3E2723; display: flex; align-items: center; gap: 8rpx; }
.picker-field { background: #F5ECD7; border: 2rpx solid rgba(58,58,85,0.5); border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #3E2723; display: flex; justify-content: space-between; }
.btn-save { margin-top: 48rpx; background: linear-gradient(135deg, #C9A96E, #6B9490); text-align: center; padding: 24rpx; border-radius: 48rpx; font-size: 32rpx; font-weight: bold; color: #F7F2E7; box-shadow: 0 0 20rpx rgba(201,169,110,0.15); }
.btn-delete { margin-top: 24rpx; text-align: center; padding: 20rpx; border-radius: 48rpx; font-size: 28rpx; color: #7D6B5D; border: 2rpx solid rgba(58,58,85,0.5); }
.btn-hover { opacity: 0.85; transform: scale(0.98); }
