<view class="page">
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="input-field" placeholder="请输入姓名" placeholder-class="placeholder" value="{{name}}" bindinput="onNameInput" />
    </view>
    <view class="form-item">
      <text class="form-label">性别</text>
      <radio-group class="radio-group" bindchange="onGenderChange">
        <label class="radio-label"><radio value="男" checked="{{gender==='男'}}" color="#88ADA6"/> 男</label>
        <label class="radio-label"><radio value="女" checked="{{gender==='女'}}" color="#88ADA6"/> 女</label>
      </radio-group>
    </view>
    <view class="form-item">
      <text class="form-label">出生日期</text>
      <picker mode="date" value="{{birthDate}}" bindchange="onDateChange">
        <view class="picker-field">{{birthDate || '请选择日期'}} ›</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">出生时辰</text>
      <picker range="{{shichenOptions}}" value="{{birthHourIndex}}" bindchange="onHourChange">
        <view class="picker-field">{{shichenOptions[birthHourIndex]}} ›</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">出生地</text>
      <input class="input-field" placeholder="如：北京" placeholder-class="placeholder" value="{{birthPlace}}" bindinput="onPlaceInput" />
    </view>
  </view>
  <view class="btn-save" bindtap="onSave" hover-class="btn-hover">
    <text>{{isEdit ? '保存修改' : '创建档案'}}</text>
  </view>
  <view class="btn-delete" bindtap="onDelete" wx:if="{{isEdit}}" hover-class="btn-hover">
    <text>删除档案</text>
  </view>
</view>
