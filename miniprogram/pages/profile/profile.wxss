.page {
  min-height: 100vh;
  background: #1A1A2E;
  padding-bottom: 140rpx;
}

/* Profile Header */
.profile-header {
  padding: 40rpx 32rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #F0EDE0;
}

.header-count {
  font-size: 24rpx;
  color: #666680;
}

/* Profile List */
.profile-list {
  padding: 0 24rpx;
}

.profile-card {
  background: #252540;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #3A3A55;
  transition: border-color 0.2s;
}

.profile-card.active {
  border-color: #88ADA6;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(136, 173, 166, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-char {
  font-size: 32rpx;
  color: #88ADA6;
  font-weight: bold;
}

.profile-info {
  flex: 1;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.profile-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #F0EDE0;
}

.active-tag {
  font-size: 20rpx;
  color: #88ADA6;
  background: rgba(136, 173, 166, 0.12);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.profile-detail {
  display: block;
  font-size: 24rpx;
  color: #666680;
  line-height: 1.5;
}

.profile-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #3A3A55;
  justify-content: flex-end;
}

.action-btn {
  font-size: 24rpx;
  color: #88ADA6;
  padding: 4rpx 16rpx;
}

.action-delete {
  color: #666680;
}

/* Add Profile */
.add-profile-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  background: #252540;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  border: 2rpx dashed #3A3A55;
  transition: border-color 0.2s;
}

.add-profile-hover {
  border-color: #88ADA6;
}

.add-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(136, 173, 166, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 32rpx;
  color: #88ADA6;
}

.add-text {
  font-size: 28rpx;
  color: #88ADA6;
}

/* Stats Card */
.stats-card {
  margin: 0 24rpx 24rpx;
  display: flex;
  align-items: center;
  background: #252540;
  border-radius: 20rpx;
  padding: 28rpx 0;
  border: 1rpx solid #3A3A55;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #88ADA6;
  margin-bottom: 4rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #666680;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #3A3A55;
}

/* Menu Section */
.menu-section {
  margin: 0 24rpx;
  background: #252540;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid #3A3A55;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #3A3A55;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background: rgba(136, 173, 166, 0.03);
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: rgba(136, 173, 166, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-char {
  font-size: 22rpx;
  color: #88ADA6;
  font-weight: bold;
}

.menu-text {
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #F0EDE0;
}

.menu-desc {
  font-size: 24rpx;
  color: #666680;
  margin-top: 2rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #3A3A55;
}

/* Footer */
.footer-text {
  text-align: center;
  margin-top: 48rpx;
  font-size: 22rpx;
  color: #666680;
}
