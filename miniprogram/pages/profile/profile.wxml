<view class="page">
  <!-- User Card -->
  <view class="user-card">
    <view class="user-info" bindtap="onGetUserInfo">
      <view class="avatar">
        <text class="avatar-text">{{hasUserInfo ? '👤' : '?'}}</text>
      </view>
      <view class="user-detail">
        <text class="nickname">{{hasUserInfo ? userInfo.nickName : '点击登录'}}</text>
        <text class="user-desc">探索命运的奥秘</text>
      </view>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{historyCount}}</text>
        <text class="stat-label">占卜次数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">8</text>
        <text class="stat-label">可用模块</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">VIP</text>
        <text class="stat-label">会员等级</text>
      </view>
    </view>
  </view>

  <!-- Menu List -->
  <view class="menu-section">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="id"
          data-id="{{item.id}}" bindtap="onMenuTap" hover-class="menu-item-hover">
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <view class="menu-text">
          <text class="menu-title">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
      </view>
      <view class="menu-right">
        <text class="menu-badge" wx:if="{{item.badge}}">{{item.badge}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer-text">
    <text>命理大师 v1.0.0</text>
  </view>
</view>
