<view class="page">
  <!-- Top Profile Bar -->
  <view class="top-bar">
    <scroll-view class="profile-scroll" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{hasProfiles}}">
      <view class="profile-list">
        <view class="profile-chip {{activeProfileId === item.id ? 'active' : ''}}"
              wx:for="{{profiles}}" wx:key="id"
              data-id="{{item.id}}" bindtap="onProfileTap">
          <view class="chip-avatar"><text class="chip-initial">{{item.name[0]}}</text></view>
          <text class="chip-name">{{item.name}}</text>
          <view class="chip-dot" wx:if="{{activeProfileId === item.id}}"></view>
        </view>
        <view class="profile-chip chip-add" bindtap="onAddProfile">
          <text class="chip-plus">+</text>
        </view>
      </view>
    </scroll-view>
    <view class="add-prompt" wx:else bindtap="onAddProfile">
      <text class="add-prompt-text">+ 添加人物档案</text>
    </view>
  </view>

  <!-- Greeting -->
  <view class="greeting-bar">
    <text class="greeting-text">{{greeting}}，一触即达千年智慧</text>
  </view>

  <!-- Module Grid: 3 columns -->
  <view class="section-header">
    <view class="section-line"></view>
    <text class="section-title">占卜方式</text>
    <view class="section-line"></view>
  </view>

  <view class="module-grid">
    <view class="module-card" wx:for="{{modules}}" wx:key="id"
          data-url="{{item.url}}" data-id="{{item.id}}" bindtap="onModuleTap"
          hover-class="module-card-hover">
      <view class="icon-circle icon-bg-{{item.id}}">
        <text class="icon-symbol icon-color-{{item.id}}">{{item.icon}}</text>
      </view>
      <text class="card-title">{{item.title}}</text>
    </view>
  </view>

  <!-- Daily Almanac -->
  <view class="daily-card">
    <view class="daily-header">
      <text class="daily-label">今日黄历</text>
      <text class="daily-date">{{dailyInfo.date}}</text>
    </view>
    <view class="daily-tags">
      <text class="daily-tag">{{dailyInfo.yearGz}}年</text>
      <text class="daily-tag">属{{dailyInfo.zodiac}}</text>
      <text class="daily-tag">{{dailyInfo.shichen}}</text>
    </view>
    <view class="daily-yiji">
      <view class="yiji-group">
        <text class="yiji-badge yi">宜</text>
        <text class="yiji-text">{{dailyInfo.yi}}</text>
      </view>
      <view class="yiji-group">
        <text class="yiji-badge ji">忌</text>
        <text class="yiji-text">{{dailyInfo.ji}}</text>
      </view>
    </view>
  </view>

  <view class="page-disclaimer">仅供娱乐参考，不作为人生决策依据</view>
</view>
