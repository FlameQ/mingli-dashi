<view class="page">
  <!-- Profile Section -->
  <view class="profile-section">
    <view class="profile-header">
      <view class="profile-header-left">
        <text class="profile-header-title">我的档案</text>
        <text class="profile-header-hint">{{greeting}} · 所有数据依据档案自动分析</text>
      </view>
      <view class="profile-header-add" wx:if="{{hasProfiles}}" bindtap="onAddProfile">
        <text class="profile-add-text">+ 新建</text>
      </view>
    </view>
    <view wx:if="{{hasProfiles}}">
      <scroll-view class="profile-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="profile-card-list">
          <view class="profile-card-item {{activeProfileId === item.id ? 'active' : ''}}"
                wx:for="{{profiles}}" wx:key="id"
                data-id="{{item.id}}" bindtap="onProfileTap"
                hover-class="profile-card-hover">
            <view class="pc-avatar"><text class="pc-avatar-char">{{item.name[0]}}</text></view>
            <view class="pc-info">
              <text class="pc-name">{{item.name}}</text>
              <text class="pc-meta">{{item.gender}} · {{item.birthDate}}</text>
            </view>
            <view class="pc-check" wx:if="{{activeProfileId === item.id}}">✓</view>
          </view>
        </view>
      </scroll-view>
    </view>
    <view class="profile-empty" wx:else bindtap="onAddProfile">
      <text class="profile-empty-icon">+</text>
      <text class="profile-empty-text">添加人物档案，开启命理推演</text>
    </view>
  </view>

  <!-- Daily Almanac -->
  <view class="daily-card">
    <view class="daily-header">
      <text class="daily-label">今日黄历</text>
      <text class="daily-date">{{dailyInfo.date}}</text>
    </view>
    <view class="daily-tags">
      <text class="daily-tag">{{dailyInfo.yearGz}}年</text>
      <text class="daily-tag">属{{dailyInfo.zodiac}}</text>
      <text class="daily-tag">{{dailyInfo.shichen}}</text>
    </view>
    <view class="daily-yiji">
      <view class="yiji-group">
        <text class="yiji-badge yi">宜</text>
        <text class="yiji-text">{{dailyInfo.yi}}</text>
      </view>
      <view class="yiji-group">
        <text class="yiji-badge ji">忌</text>
        <text class="yiji-text">{{dailyInfo.ji}}</text>
      </view>
    </view>

    <!-- Personal Fortune -->
    <view class="personal-fortune" wx:if="{{personalFortune}}">
      <view class="zen-divider"></view>
      <view class="pf-header">
        <text class="pf-title">{{personalFortune.name}} · 今日运势</text>
        <text class="pf-level {{personalFortune.fortuneLevel === '大吉' || personalFortune.fortuneLevel === '吉' ? 'pf-level-good' : personalFortune.fortuneLevel === '凶' || personalFortune.fortuneLevel === '小凶' ? 'pf-level-bad' : ''}}">{{personalFortune.fortuneLevel}}</text>
      </view>
      <text class="pf-advice">{{personalFortune.advice}}</text>
      <view class="pf-details">
        <view class="pf-detail-item">
          <text class="pf-detail-label">吉星</text>
          <text class="pf-detail-value">{{personalFortune.luckyStars[0]}} · {{personalFortune.luckyStars[1]}}</text>
        </view>
        <view class="pf-detail-item">
          <text class="pf-detail-label">方位</text>
          <text class="pf-detail-value">{{personalFortune.direction}}</text>
        </view>
        <view class="pf-detail-item">
          <text class="pf-detail-label">幸运</text>
          <text class="pf-detail-value">{{personalFortune.luckyNum}} · {{personalFortune.luckyColor}}色</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Daily Hexagram Card -->
  <view class="gua-card" bindtap="onStartDivination">
    <view class="gua-card-header">
      <text class="gua-card-label">每日一卦</text>
      <text class="gua-card-date">{{dailyGua.date}}</text>
    </view>
    <view class="gua-card-body">
      <view class="gua-symbol-area">
        <text class="gua-big-name">{{dailyGua.name}}</text>
        <view class="gua-yao-display">
          <text class="gua-yao-line" wx:for="{{dailyGua.yaos}}" wx:key="index">{{item.line}}</text>
        </view>
      </view>
      <view class="gua-reading-area">
        <text class="gua-reading-text">{{dailyGua.reading}}</text>
        <text class="gua-tap-hint">点击摇铜钱起卦 ›</text>
      </view>
    </view>
  </view>

  <!-- Module Groups -->
  <view class="module-section" wx:for="{{moduleGroups}}" wx:key="id">
    <view class="group-header">
      <view class="group-line"></view>
      <text class="group-title">{{item.title}}</text>
      <view class="group-line"></view>
    </view>
    <view class="module-grid">
      <view class="module-card" wx:for="{{item.modules}}" wx:key="id"
            data-url="{{item.url}}" data-id="{{item.id}}" bindtap="onModuleTap"
            hover-class="module-card-hover">
        <view class="icon-circle icon-bg-{{item.id}}">
          <text class="icon-symbol icon-color-{{item.id}}">{{item.icon}}</text>
        </view>
        <text class="card-title">{{item.title}}</text>
      </view>
    </view>
  </view>

  <view class="page-disclaimer">仅供娱乐参考，不作为人生决策依据</view>

  <!-- ===== Coin Divination Modal ===== -->
  <view class="coin-modal" wx:if="{{showCoinModal}}">
    <view class="coin-modal-mask" bindtap="onCloseDivination"></view>
    <view class="coin-modal-body">
      <view class="coin-modal-header">
        <text class="coin-modal-title">铜钱起卦</text>
        <text class="coin-modal-close" bindtap="onCloseDivination">✕</text>
      </view>

      <!-- Method Info -->
      <view class="coin-method-info">
        <text class="coin-method-text">三枚铜钱，字为阳(3)背为阴(2)，掷六次成一卦</text>
      </view>

      <!-- Progress -->
      <view class="coin-progress" wx:if="{{!hexagramResult}}">
        <text class="coin-progress-text">第 {{coinRound < 6 ? coinRound + 1 : 6}} / 6 次掷卦</text>
        <view class="coin-progress-dots">
          <view class="coin-dot {{index < coinRound ? 'done' : ''}}" wx:for="{{6}}" wx:key="*this"></view>
        </view>
      </view>

      <!-- Coin Tossing Area -->
      <view class="coin-area" wx:if="{{!hexagramResult}}">
        <view class="coins-row">
          <view class="coin-wrap">
            <view class="coin {{isFlipping ? 'coin-flip' : ''}} {{coins[0] === 3 ? 'coin-heads' : coins[0] === 2 ? 'coin-tails' : ''}}">
              <text class="coin-text" wx:if="{{coins[0] === 3}}">字</text>
              <text class="coin-text" wx:elif="{{coins[0] === 2}}">背</text>
              <text class="coin-text coin-unknown" wx:else>?</text>
            </view>
            <text class="coin-value-label">{{coinValues[0]}}</text>
          </view>
          <view class="coin-wrap">
            <view class="coin {{isFlipping ? 'coin-flip' : ''}} {{coins[1] === 3 ? 'coin-heads' : coins[1] === 2 ? 'coin-tails' : ''}}">
              <text class="coin-text" wx:if="{{coins[1] === 3}}">字</text>
              <text class="coin-text" wx:elif="{{coins[1] === 2}}">背</text>
              <text class="coin-text coin-unknown" wx:else>?</text>
            </view>
            <text class="coin-value-label">{{coinValues[1]}}</text>
          </view>
          <view class="coin-wrap">
            <view class="coin {{isFlipping ? 'coin-flip' : ''}} {{coins[2] === 3 ? 'coin-heads' : coins[2] === 2 ? 'coin-tails' : ''}}">
              <text class="coin-text" wx:if="{{coins[2] === 3}}">字</text>
              <text class="coin-text" wx:elif="{{coins[2] === 2}}">背</text>
              <text class="coin-text coin-unknown" wx:else>?</text>
            </view>
            <text class="coin-value-label">{{coinValues[2]}}</text>
          </view>
        </view>

        <view class="coin-toss-btn {{isFlipping ? 'disabled' : ''}}" bindtap="onTossCoins">
          <text>{{isFlipping ? '摇卦中...' : '摇  卦'}}</text>
        </view>

        <!-- Lines built so far -->
        <view class="coin-lines-built" wx:if="{{coinLines.length > 0}}">
          <view class="coin-built-title">已成爻</view>
          <view class="coin-built-line" wx:for="{{coinLines}}" wx:key="position">
            <text class="coin-built-num">{{item.position}}</text>
            <text class="coin-built-symbol {{item.isMoving ? 'moving' : ''}}">{{item.lineSymbol}}</text>
            <text class="coin-built-type {{item.isMoving ? 'moving-type' : ''}}">{{item.lineType}}</text>
          </view>
        </view>
      </view>

      <!-- Hexagram Result -->
      <view class="coin-result" wx:if="{{hexagramResult}}">
        <view class="coin-result-header">
          <text class="coin-result-gua">{{hexagramResult.name}}卦</text>
        </view>
        <view class="coin-result-lines">
          <view class="coin-result-line" wx:for="{{hexagramResult.lines}}" wx:key="position">
            <text class="coin-result-line-num">{{item.position}}</text>
            <text class="coin-result-line-sym {{item.isMoving ? 'moving' : ''}}">{{item.lineSymbol}}</text>
            <text class="coin-result-line-type {{item.isMoving ? 'moving-type' : 'dim-type'}}">{{item.lineType}}</text>
          </view>
        </view>
        <view class="coin-result-moving" wx:if="{{hexagramResult.movingLines.length > 0}}">
          <text class="coin-moving-text">动爻：{{hexagramResult.movingLines.join('、')}}</text>
        </view>
        <text class="coin-result-reading">{{hexagramResult.reading}}</text>
        <view class="coin-result-btns">
          <view class="coin-retry-btn" bindtap="onResetDivination"><text>重新起卦</text></view>
          <view class="coin-close-btn" bindtap="onCloseDivination"><text>关闭</text></view>
        </view>
      </view>
    </view>
  </view>
</view>
