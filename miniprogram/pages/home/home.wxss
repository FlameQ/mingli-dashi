.page {
  min-height: 100vh;
  background: #1A1A2E;
  padding-bottom: 140rpx;
}

/* ===== Top Profile Bar ===== */
.top-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(26, 26, 46, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  padding: 16rpx 0 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.profile-scroll {
  white-space: nowrap;
  padding-left: 24rpx;
}

.profile-list {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding-right: 24rpx;
}

.profile-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx;
  background: rgba(58, 58, 85, 0.5);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: all 0.2s;
}

.profile-chip.active {
  background: rgba(136, 173, 166, 0.15);
  border-color: rgba(136, 173, 166, 0.4);
}

.chip-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(136, 173, 166, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.active .chip-avatar {
  background: rgba(136, 173, 166, 0.3);
}

.chip-initial {
  font-size: 22rpx;
  color: #88ADA6;
  font-weight: bold;
}

.chip-name {
  font-size: 24rpx;
  color: #A0A0B8;
  font-weight: 500;
}

.active .chip-name {
  color: #88ADA6;
  font-weight: bold;
}

.chip-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #88ADA6;
}

.chip-add {
  padding: 10rpx 24rpx;
  border-style: dashed;
  border-color: rgba(136, 173, 166, 0.2);
}

.chip-plus {
  font-size: 28rpx;
  color: #666680;
}

.add-prompt {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
}

.add-prompt-text {
  font-size: 26rpx;
  color: #88ADA6;
  padding: 10rpx 32rpx;
  border: 1rpx dashed rgba(136, 173, 166, 0.25);
  border-radius: 40rpx;
}

/* ===== Compact Info Bar ===== */
.info-bar {
  padding: 24rpx 28rpx 20rpx;
}

.greeting-row {
  margin-bottom: 12rpx;
}

.greeting-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #F0EDE0;
  letter-spacing: 2rpx;
}

.daily-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.daily-tag {
  font-size: 22rpx;
  color: #88ADA6;
  background: rgba(136, 173, 166, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.daily-date {
  font-size: 22rpx;
  color: #666680;
  margin-left: auto;
}

.yiji-row {
  display: flex;
  gap: 24rpx;
}

.yiji-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.yiji-badge {
  font-size: 22rpx;
  font-weight: bold;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.yiji-badge.yi {
  background: rgba(123, 169, 143, 0.18);
  color: #7BA98F;
}

.yiji-badge.ji {
  background: rgba(201, 185, 138, 0.18);
  color: #C9B98A;
}

.yiji-text {
  font-size: 22rpx;
  color: #A0A0B8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== Active Profile Hint ===== */
.active-hint {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 28rpx 12rpx;
}

.hint-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #88ADA6;
}

.hint-text {
  font-size: 22rpx;
  color: #88ADA6;
}

/* ===== Section Header ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 28rpx 12rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #666680;
  white-space: nowrap;
  letter-spacing: 4rpx;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(58, 58, 85, 0.6), transparent);
}

.section-line:first-child {
  background: linear-gradient(90deg, transparent, rgba(58, 58, 85, 0.6));
}

/* ===== Module Grid ===== */
.module-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 4rpx 20rpx;
}

.module-card {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(37, 37, 64, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.2s ease;
}

.module-card-hover {
  transform: scale(0.97);
}

/* Card left accent line per module */
.card-bazi { border-left: 4rpx solid #4ECDC4; }
.card-qimen { border-left: 4rpx solid #6688CC; }
.card-ziwei { border-left: 4rpx solid #9966CC; }
.card-yinyuan { border-left: 4rpx solid #D4A574; }
.card-tarot { border-left: 4rpx solid #CC9944; }
.card-liuyao { border-left: 4rpx solid #66AA88; }
.card-fengshui { border-left: 4rpx solid #55AACC; }
.card-buddhism { border-left: 4rpx solid #CCAA66; }

/* ===== Icon Circles - VIVID per module ===== */
.icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-symbol {
  font-size: 36rpx;
  font-weight: bold;
  position: relative;
  z-index: 2;
}

/* ☯ 八字排盘 - Teal */
.icon-bg-bazi {
  background: linear-gradient(135deg, #1A4A4A, #0D2E2E);
  box-shadow: 0 4rpx 20rpx rgba(78, 205, 196, 0.25);
}
.icon-color-bazi { color: #4ECDC4; }

/* ✦ 奇门遁甲 - Steel Blue */
.icon-bg-qimen {
  background: linear-gradient(135deg, #1A2A5A, #101838);
  box-shadow: 0 4rpx 20rpx rgba(102, 136, 204, 0.25);
}
.icon-color-qimen { color: #6688CC; }

/* ★ 紫微斗数 - Purple */
.icon-bg-ziwei {
  background: linear-gradient(135deg, #2A1A5A, #181030);
  box-shadow: 0 4rpx 20rpx rgba(153, 102, 204, 0.25);
}
.icon-color-ziwei { color: #9966CC; }

/* ♡ 月老姻缘 - Rose Gold */
.icon-bg-yinyuan {
  background: linear-gradient(135deg, #4A3020, #2E1E14);
  box-shadow: 0 4rpx 20rpx rgba(212, 165, 116, 0.25);
}
.icon-color-yinyuan { color: #D4A574; }

/* ◆ 塔罗占卜 - Amber */
.icon-bg-tarot {
  background: linear-gradient(135deg, #3A2A0A, #241A06);
  box-shadow: 0 4rpx 20rpx rgba(204, 153, 68, 0.25);
}
.icon-color-tarot { color: #CC9944; }

/* ☰ 六爻占卦 - Sage Green */
.icon-bg-liuyao {
  background: linear-gradient(135deg, #1A3A2A, #0E241A);
  box-shadow: 0 4rpx 20rpx rgba(102, 170, 136, 0.25);
}
.icon-color-liuyao { color: #66AA88; }

/* ≈ 易经风水 - Ocean */
.icon-bg-fengshui {
  background: linear-gradient(135deg, #1A3A4A, #0E2430);
  box-shadow: 0 4rpx 20rpx rgba(85, 170, 204, 0.25);
}
.icon-color-fengshui { color: #55AACC; }

/* ☸ 佛学大师 - Warm Gold */
.icon-bg-buddhism {
  background: linear-gradient(135deg, #3A3020, #241E14);
  box-shadow: 0 4rpx 20rpx rgba(204, 170, 102, 0.25);
}
.icon-color-buddhism { color: #CCAA66; }

/* ===== Card Text ===== */
.card-text {
  flex: 1;
  min-width: 0;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #F0EDE0;
  margin-bottom: 4rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #666680;
}

/* ===== Disclaimer ===== */
.page-disclaimer {
  text-align: center;
  color: #666680;
  font-size: 22rpx;
  padding: 40rpx 24rpx 20rpx;
}
