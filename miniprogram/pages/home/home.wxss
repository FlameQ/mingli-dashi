.page {
  min-height: 100vh;
  background: #FFFBF0;
  padding-bottom: 120rpx;
}

/* Hero Banner */
.hero-banner {
  position: relative;
  padding: 80rpx 40rpx 60rpx;
  background: linear-gradient(180deg, #AA2116 0%, #C93756 60%, #FFFBF0 100%);
  overflow: hidden;
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
}

.title-main {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #FFF8E7;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
  letter-spacing: 16rpx;
}

.title-decoration {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 16rpx 0;
}

.deco-line {
  width: 80rpx;
  height: 2rpx;
  background: rgba(255, 248, 231, 0.6);
}

.deco-dot {
  color: #D4A017;
  font-size: 16rpx;
  margin: 0 16rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 248, 231, 0.9);
  margin-top: 8rpx;
}

.cloud-deco {
  position: absolute;
  font-size: 120rpx;
  opacity: 0.1;
  color: #FFF;
  z-index: 1;
}

.cloud-left {
  top: 20rpx;
  left: -20rpx;
}

.cloud-right {
  bottom: 80rpx;
  right: -20rpx;
}

/* 今日黄历 */
.daily-section {
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 3;
  background: #FFF8E7;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(60, 36, 21, 0.12);
}

.daily-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.daily-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3C2415;
}

.daily-date {
  font-size: 24rpx;
  color: #8B7355;
}

.daily-ganzhi {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ganzhi-tag {
  font-size: 22rpx;
  color: #AA2116;
  background: rgba(170, 33, 22, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(170, 33, 22, 0.15);
}

.daily-yiji {
  display: flex;
  gap: 24rpx;
}

.yi-ji-item {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.yi-ji-label {
  font-size: 26rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.yi-ji-label.yi {
  background: rgba(107, 158, 60, 0.15);
  color: #4A7A1A;
}

.yi-ji-label.ji {
  background: rgba(240, 112, 80, 0.15);
  color: #D4503A;
}

.yi-ji-text {
  font-size: 24rpx;
  color: #8B7355;
  line-height: 1.5;
}

/* Section Header */
.section-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 24rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3C2415;
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, #E8D5A3, transparent);
}

/* Module Grid */
.module-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 16rpx;
}

.module-card {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  background: #FFF8E7;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(60, 36, 21, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  border: 1rpx solid rgba(232, 213, 163, 0.5);
}

.module-card-hover {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(60, 36, 21, 0.1);
}

.card-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.icon-emoji {
  font-size: 48rpx;
}

.card-text {
  text-align: center;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #3C2415;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #8B7355;
}

.disclaimer {
  text-align: center;
  color: #BBA88A;
  font-size: 22rpx;
  padding: 40rpx 0 20rpx;
}
