.page {
  min-height: 100vh;
  background: #1A1A2E;
  padding-bottom: 140rpx;
}

/* Hero Section */
.hero {
  padding: 100rpx 40rpx 80rpx;
  background: linear-gradient(180deg, #252540 0%, #1A1A2E 100%);
  text-align: center;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-title {
  font-size: 72rpx;
  font-weight: bold;
  color: #F0EDE0;
  letter-spacing: 24rpx;
  line-height: 1.2;
}

.hero-divider {
  width: 80rpx;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #88ADA6, transparent);
  margin: 24rpx 0;
}

.hero-subtitle {
  font-size: 28rpx;
  color: #A0A0B8;
  letter-spacing: 4rpx;
}

/* Daily Almanac Card */
.daily-card {
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 3;
  background: #252540;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #3A3A55;
}

.daily-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.daily-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #F0EDE0;
}

.daily-date {
  font-size: 24rpx;
  color: #666680;
}

.daily-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.daily-tag {
  font-size: 22rpx;
  color: #88ADA6;
  background: rgba(136, 173, 166, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(136, 173, 166, 0.2);
}

.daily-yiji {
  display: flex;
  gap: 24rpx;
}

.yiji-block {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.yiji-label {
  font-size: 26rpx;
  font-weight: bold;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.yiji-label.yiji-yi {
  background: rgba(123, 169, 143, 0.15);
  color: #7BA98F;
}

.yiji-label.yiji-ji {
  background: rgba(201, 185, 138, 0.15);
  color: #C9B98A;
}

.yiji-text {
  font-size: 24rpx;
  color: #A0A0B8;
  line-height: 1.6;
}

/* Section Header */
.section-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 24rpx 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #A0A0B8;
  white-space: nowrap;
  letter-spacing: 4rpx;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, #3A3A55, transparent);
}

.section-line:first-child {
  background: linear-gradient(90deg, transparent, #3A3A55);
}

/* Module Grid */
.module-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 16rpx;
}

.module-card {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  background: #252540;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid #3A3A55;
  transition: transform 0.2s ease;
}

.module-card-hover {
  transform: scale(0.97);
  border-color: #88ADA6;
}

.card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  background: rgba(136, 173, 166, 0.1);
  border: 1rpx solid rgba(136, 173, 166, 0.2);
}

.card-icon-char {
  font-size: 36rpx;
  color: #88ADA6;
  font-weight: bold;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #F0EDE0;
  margin-bottom: 8rpx;
  text-align: center;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #666680;
  text-align: center;
}

/* Disclaimer */
.page-disclaimer {
  text-align: center;
  color: #666680;
  font-size: 22rpx;
  padding: 40rpx 24rpx 20rpx;
}
