.page {
  min-height: 100vh;
  background: #F7F3EC;
  padding-bottom: 140rpx;
}

/* ===== Top Profile Bar ===== */
.top-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 252, 245, 0.95);
  padding: 16rpx 0 12rpx;
  border-bottom: 1rpx solid #E5DFD3;
}

.profile-scroll {
  white-space: nowrap;
  padding-left: 24rpx;
}

.profile-list {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding-right: 24rpx;
}

.profile-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx;
  background: #FFFCF5;
  border-radius: 40rpx;
  border: 1rpx solid #E5DFD3;
  transition: all 0.2s;
}

.profile-chip.active {
  background: rgba(74, 124, 138, 0.08);
  border-color: #4A7C8A;
}

.chip-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(74, 124, 138, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.active .chip-avatar {
  background: rgba(74, 124, 138, 0.2);
}

.chip-initial {
  font-size: 22rpx;
  color: #4A7C8A;
  font-weight: bold;
}

.chip-name {
  font-size: 24rpx;
  color: #7A7A7A;
  font-weight: 500;
}

.active .chip-name {
  color: #4A7C8A;
  font-weight: bold;
}

.chip-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #4A7C8A;
}

.chip-add {
  padding: 10rpx 24rpx;
  border-style: dashed;
  border-color: #D0C8B8;
}

.chip-plus {
  font-size: 28rpx;
  color: #AAAAAA;
}

.add-prompt {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
}

.add-prompt-text {
  font-size: 26rpx;
  color: #4A7C8A;
  padding: 10rpx 32rpx;
  border: 1rpx dashed #D0C8B8;
  border-radius: 40rpx;
}

/* ===== Compact Info Bar ===== */
.info-bar {
  padding: 24rpx 28rpx 20rpx;
  background: linear-gradient(180deg, #F5F0E8 0%, #F7F3EC 100%);
}

.greeting-row {
  margin-bottom: 12rpx;
}

.greeting-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #2D2D2D;
  letter-spacing: 2rpx;
}

.daily-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.daily-tag {
  font-size: 22rpx;
  color: #4A7C8A;
  background: rgba(74, 124, 138, 0.08);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.daily-date {
  font-size: 22rpx;
  color: #AAAAAA;
  margin-left: auto;
}

.yiji-row {
  display: flex;
  gap: 24rpx;
}

.yiji-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.yiji-badge {
  font-size: 22rpx;
  font-weight: bold;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.yiji-badge.yi {
  background: rgba(91, 138, 114, 0.12);
  color: #5B8A72;
}

.yiji-badge.ji {
  background: rgba(184, 149, 42, 0.12);
  color: #B8952A;
}

.yiji-text {
  font-size: 22rpx;
  color: #7A7A7A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== Active Profile Hint ===== */
.active-hint {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 28rpx 12rpx;
}

.hint-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #4A7C8A;
}

.hint-text {
  font-size: 22rpx;
  color: #4A7C8A;
}

/* ===== Section Header ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 28rpx 12rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #AAAAAA;
  white-space: nowrap;
  letter-spacing: 4rpx;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, #E5DFD3, transparent);
}

.section-line:first-child {
  background: linear-gradient(90deg, transparent, #E5DFD3);
}

/* ===== Module Grid ===== */
.module-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 4rpx 20rpx;
}

.module-card {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFFCF5;
  border: 1rpx solid #E5DFD3;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.module-card-hover {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* Card left accent line per module */
.card-bazi { border-left: 4rpx solid #2D7A72; }
.card-qimen { border-left: 4rpx solid #3A5A8A; }
.card-ziwei { border-left: 4rpx solid #5A3A8A; }
.card-yinyuan { border-left: 4rpx solid #8A5A3A; }
.card-tarot { border-left: 4rpx solid #8A6A20; }
.card-liuyao { border-left: 4rpx solid #2D6A4A; }
.card-fengshui { border-left: 4rpx solid #2A5A7A; }
.card-buddhism { border-left: 4rpx solid #8A7A30; }

/* ===== Icon Circles ===== */
.icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-symbol {
  font-size: 36rpx;
  font-weight: bold;
  position: relative;
  z-index: 2;
}

/* ☯ 八字排盘 - Teal */
.icon-bg-bazi {
  background: linear-gradient(135deg, #E8F4F2, #D4EBE7);
  box-shadow: 0 4rpx 16rpx rgba(45, 122, 114, 0.15);
}
.icon-color-bazi { color: #2D7A72; }

/* ✦ 奇门遁甲 - Blue */
.icon-bg-qimen {
  background: linear-gradient(135deg, #E8ECF5, #D4D9ED);
  box-shadow: 0 4rpx 16rpx rgba(58, 90, 138, 0.15);
}
.icon-color-qimen { color: #3A5A8A; }

/* ★ 紫微斗数 - Purple */
.icon-bg-ziwei {
  background: linear-gradient(135deg, #EDE8F5, #DDD6ED);
  box-shadow: 0 4rpx 16rpx rgba(90, 58, 138, 0.15);
}
.icon-color-ziwei { color: #5A3A8A; }

/* ♡ 月老姻缘 - Rose */
.icon-bg-yinyuan {
  background: linear-gradient(135deg, #F5EDE8, #EDDDD6);
  box-shadow: 0 4rpx 16rpx rgba(138, 90, 58, 0.15);
}
.icon-color-yinyuan { color: #8A5A3A; }

/* ◆ 塔罗占卜 - Amber */
.icon-bg-tarot {
  background: linear-gradient(135deg, #F5F0E0, #EDE6D0);
  box-shadow: 0 4rpx 16rpx rgba(138, 106, 32, 0.15);
}
.icon-color-tarot { color: #8A6A20; }

/* ☰ 六爻占卦 - Green */
.icon-bg-liuyao {
  background: linear-gradient(135deg, #E8F2EC, #D4E8DD);
  box-shadow: 0 4rpx 16rpx rgba(45, 106, 74, 0.15);
}
.icon-color-liuyao { color: #2D6A4A; }

/* ≈ 易经风水 - Ocean */
.icon-bg-fengshui {
  background: linear-gradient(135deg, #E8F0F5, #D4E3ED);
  box-shadow: 0 4rpx 16rpx rgba(42, 90, 122, 0.15);
}
.icon-color-fengshui { color: #2A5A7A; }

/* ☸ 佛学大师 - Gold */
.icon-bg-buddhism {
  background: linear-gradient(135deg, #F5F0E0, #EDE6CC);
  box-shadow: 0 4rpx 16rpx rgba(138, 122, 48, 0.15);
}
.icon-color-buddhism { color: #8A7A30; }

/* ===== Card Text ===== */
.card-text {
  flex: 1;
  min-width: 0;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #AAAAAA;
}

/* ===== Disclaimer ===== */
.page-disclaimer {
  text-align: center;
  color: #AAAAAA;
  font-size: 22rpx;
  padding: 40rpx 24rpx 20rpx;
}
