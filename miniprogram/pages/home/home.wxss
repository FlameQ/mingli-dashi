.page {
  min-height: 100vh;
  background: #1A1A2E;
  padding-bottom: 140rpx;
}

/* ===== Hero Section ===== */
.hero {
  padding: 100rpx 40rpx 80rpx;
  background: linear-gradient(180deg, #252540 0%, #1A1A2E 100%);
  text-align: center;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-title {
  font-size: 72rpx;
  font-weight: bold;
  color: #F0EDE0;
  letter-spacing: 24rpx;
  line-height: 1.2;
}

.hero-divider {
  width: 80rpx;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #88ADA6, transparent);
  margin: 24rpx 0;
}

.hero-subtitle {
  font-size: 28rpx;
  color: #A0A0B8;
  letter-spacing: 4rpx;
}

/* ===== Daily Almanac Card ===== */
.daily-card {
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 3;
  background: rgba(37, 37, 64, 0.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.daily-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.daily-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #F0EDE0;
}

.daily-date {
  font-size: 24rpx;
  color: #666680;
}

.daily-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.daily-tag {
  font-size: 22rpx;
  color: #88ADA6;
  background: rgba(136, 173, 166, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(136, 173, 166, 0.2);
}

.daily-yiji {
  display: flex;
  gap: 24rpx;
}

.yiji-block {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.yiji-label {
  font-size: 26rpx;
  font-weight: bold;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.yiji-label.yiji-yi {
  background: rgba(123, 169, 143, 0.15);
  color: #7BA98F;
}

.yiji-label.yiji-ji {
  background: rgba(201, 185, 138, 0.15);
  color: #C9B98A;
}

.yiji-text {
  font-size: 24rpx;
  color: #A0A0B8;
  line-height: 1.6;
}

/* ===== Profile Selector ===== */
.profile-section {
  padding: 8rpx 24rpx 0;
}

.profile-scroll {
  white-space: nowrap;
}

.profile-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 12rpx 0;
}

.profile-chip {
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 20rpx;
  background: rgba(37, 37, 64, 0.75);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.03);
  transition: all 0.25s ease;
}

.profile-chip-active {
  border-color: rgba(136, 173, 166, 0.4);
  background: rgba(136, 173, 166, 0.08);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.03), 0 0 16rpx rgba(136, 173, 166, 0.08);
}

.profile-chip-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(136, 173, 166, 0.12);
  border: 1rpx solid rgba(136, 173, 166, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-chip-active .profile-chip-avatar {
  background: rgba(136, 173, 166, 0.2);
  border-color: rgba(136, 173, 166, 0.4);
}

.profile-chip-initial {
  font-size: 24rpx;
  color: #88ADA6;
  font-weight: bold;
}

.profile-chip-info-wrap {
  display: flex;
  flex-direction: column;
}

.profile-chip-name {
  font-size: 26rpx;
  color: #F0EDE0;
  font-weight: bold;
  line-height: 1.3;
}

.profile-chip-active .profile-chip-name {
  color: #88ADA6;
}

.profile-chip-detail {
  font-size: 20rpx;
  color: #666680;
  line-height: 1.3;
}

.profile-chip-add {
  justify-content: center;
  padding: 14rpx 24rpx;
  border-style: dashed;
  border-color: rgba(255, 255, 255, 0.08);
}

.profile-chip-plus {
  font-size: 32rpx;
  color: #666680;
  line-height: 1;
}

/* ===== Profile Prompt (no profiles) ===== */
.profile-prompt {
  padding: 8rpx 24rpx 0;
}

.profile-prompt-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(37, 37, 64, 0.5);
  border-radius: 20rpx;
  border: 1rpx dashed rgba(136, 173, 166, 0.2);
}

.profile-prompt-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(136, 173, 166, 0.1);
  border: 1rpx solid rgba(136, 173, 166, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #88ADA6;
  text-align: center;
  line-height: 44rpx;
}

.profile-prompt-text {
  font-size: 26rpx;
  color: #A0A0B8;
}

/* ===== Section Header ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 24rpx 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #A0A0B8;
  white-space: nowrap;
  letter-spacing: 4rpx;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, #3A3A55, transparent);
}

.section-line:first-child {
  background: linear-gradient(90deg, transparent, #3A3A55);
}

/* ===== Module Grid ===== */
.module-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 16rpx;
}

.module-card {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  background: rgba(37, 37, 64, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.03);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.module-card-hover {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15), inset 0 1rpx 0 rgba(255, 255, 255, 0.03);
}

/* ===== Module Icons - Design System ===== */
.card-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

.icon-deco-a, .icon-deco-b {
  position: absolute;
  pointer-events: none;
}

.card-icon-char {
  position: relative;
  z-index: 2;
  font-weight: bold;
}

/* --- 命 八字排盘: 八角形 + 十字线 --- */
.icon-bazi {
  border-radius: 28%;
  background: linear-gradient(135deg, rgba(136, 173, 166, 0.25) 0%, rgba(136, 173, 166, 0.05) 100%);
  border: 1.5rpx solid rgba(136, 173, 166, 0.3);
  box-shadow: 0 4rpx 24rpx rgba(136, 173, 166, 0.12);
}

.deco-bazi.icon-deco-a {
  width: 100%;
  height: 1rpx;
  background: rgba(136, 173, 166, 0.12);
  top: 50%;
  left: 0;
}

.deco-bazi.icon-deco-b {
  width: 1rpx;
  height: 100%;
  background: rgba(136, 173, 166, 0.12);
  left: 50%;
  top: 0;
}

.char-bazi {
  font-size: 36rpx;
  color: #88ADA6;
}

/* --- 遁 奇门遁甲: 旋转菱形 + 内圆 --- */
.icon-qimen {
  border-radius: 12rpx;
  transform: rotate(45deg);
  background: linear-gradient(135deg, rgba(120, 145, 190, 0.25) 0%, rgba(120, 145, 190, 0.05) 100%);
  border: 1.5rpx solid rgba(120, 145, 190, 0.3);
  box-shadow: 0 4rpx 24rpx rgba(120, 145, 190, 0.12);
}

.deco-qimen.icon-deco-a {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(120, 145, 190, 0.2);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.deco-qimen.icon-deco-b {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: rgba(120, 145, 190, 0.08);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.char-qimen {
  font-size: 32rpx;
  color: #7891BE;
  transform: rotate(-45deg);
}

/* --- 星 紫微斗数: 星环 + 四点 --- */
.icon-ziwei {
  border-radius: 50%;
  background: radial-gradient(circle, rgba(160, 150, 210, 0.2) 0%, rgba(100, 90, 160, 0.05) 100%);
  border: 1.5rpx solid rgba(160, 150, 210, 0.3);
  box-shadow: 0 4rpx 24rpx rgba(160, 150, 210, 0.12);
}

.deco-ziwei.icon-deco-a {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(160, 150, 210, 0.4);
  top: 12rpx;
  left: 50%;
  margin-left: -3rpx;
  box-shadow: 0 64rpx 0 rgba(160, 150, 210, 0.4), -32rpx 32rpx 0 rgba(160, 150, 210, 0.3), 32rpx 32rpx 0 rgba(160, 150, 210, 0.3);
}

.deco-ziwei.icon-deco-b {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 1rpx dashed rgba(160, 150, 210, 0.15);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.char-ziwei {
  font-size: 34rpx;
  color: #A096D2;
}

/* --- 缘 月老姻缘: 月牙双环 --- */
.icon-yinyuan {
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(201, 185, 138, 0.2) 0%, rgba(201, 185, 138, 0.04) 100%);
  border: 1.5rpx solid rgba(201, 185, 138, 0.3);
  box-shadow: 0 4rpx 24rpx rgba(201, 185, 138, 0.1), inset 0 0 20rpx rgba(201, 185, 138, 0.06);
}

.deco-yinyuan.icon-deco-a {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(201, 185, 138, 0.18);
  top: 10rpx;
  right: 10rpx;
}

.deco-yinyuan.icon-deco-b {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(201, 185, 138, 0.12);
  bottom: 14rpx;
  left: 14rpx;
}

.char-yinyuan {
  font-size: 34rpx;
  color: #C9B98A;
}

/* --- 牌 塔罗占卜: 竖长卡牌 + 角标 --- */
.icon-tarot {
  border-radius: 12rpx;
  width: 66rpx;
  height: 90rpx;
  background: linear-gradient(180deg, rgba(160, 130, 100, 0.2) 0%, rgba(120, 90, 70, 0.04) 100%);
  border: 1.5rpx solid rgba(160, 130, 100, 0.3);
  box-shadow: 0 4rpx 24rpx rgba(160, 130, 100, 0.12);
}

.deco-tarot.icon-deco-a {
  width: 14rpx;
  height: 14rpx;
  border-top: 1rpx solid rgba(160, 130, 100, 0.35);
  border-left: 1rpx solid rgba(160, 130, 100, 0.35);
  top: 10rpx;
  left: 10rpx;
}

.deco-tarot.icon-deco-b {
  width: 14rpx;
  height: 14rpx;
  border-bottom: 1rpx solid rgba(160, 130, 100, 0.35);
  border-right: 1rpx solid rgba(160, 130, 100, 0.35);
  bottom: 10rpx;
  right: 10rpx;
}

.char-tarot {
  font-size: 30rpx;
  color: #A08264;
}

/* --- 卦 六爻占卦: 方形 + 三横线 --- */
.icon-liuyao {
  border-radius: 10rpx;
  background: linear-gradient(135deg, rgba(123, 169, 143, 0.2) 0%, rgba(100, 140, 130, 0.04) 100%);
  border: 1.5rpx solid rgba(123, 169, 143, 0.3);
  box-shadow: 0 4rpx 24rpx rgba(123, 169, 143, 0.12);
}

.deco-liuyao.icon-deco-a {
  width: 44rpx;
  height: 1rpx;
  background: rgba(123, 169, 143, 0.2);
  top: 24rpx;
  left: 22rpx;
  box-shadow: 0 18rpx 0 rgba(123, 169, 143, 0.2), 0 36rpx 0 rgba(123, 169, 143, 0.15);
}

.deco-liuyao.icon-deco-b {
  display: none;
}

.char-liuyao {
  font-size: 34rpx;
  color: #7BA98F;
}

/* --- 风 易经风水: 圆形 + 同心波纹 --- */
.icon-fengshui {
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(100, 170, 140, 0.2) 0%, rgba(80, 150, 120, 0.04) 100%);
  border: 1.5rpx solid rgba(100, 170, 140, 0.3);
  box-shadow: 0 4rpx 24rpx rgba(100, 170, 140, 0.12);
}

.deco-fengshui.icon-deco-a {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(100, 170, 140, 0.12);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.deco-fengshui.icon-deco-b {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(100, 170, 140, 0.08);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.char-fengshui {
  font-size: 34rpx;
  color: #64AA8C;
}

/* --- 禅 佛学大师: 禅圆 + 极简 --- */
.icon-buddhism {
  border-radius: 50%;
  background: rgba(201, 185, 138, 0.06);
  border: 2.5rpx solid rgba(201, 185, 138, 0.25);
  box-shadow: 0 4rpx 24rpx rgba(201, 185, 138, 0.08);
}

.deco-buddhism.icon-deco-a {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(201, 185, 138, 0.08);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.deco-buddhism.icon-deco-b {
  display: none;
}

.char-buddhism {
  font-size: 34rpx;
  color: #C9B98A;
}

/* ===== Card Text ===== */
.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #F0EDE0;
  margin-bottom: 8rpx;
  text-align: center;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #666680;
  text-align: center;
}

/* ===== Disclaimer ===== */
.page-disclaimer {
  text-align: center;
  color: #666680;
  font-size: 22rpx;
  padding: 40rpx 24rpx 20rpx;
}
