.page {
  min-height: 100vh;
  background: #FFFBF0;
  padding-bottom: 120rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 34rpx;
  color: #3C2415;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #8B7355;
}

.history-list {
  padding: 24rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.list-count {
  font-size: 26rpx;
  color: #8B7355;
}

.clear-btn {
  font-size: 26rpx;
  color: #AA2116;
  padding: 8rpx 24rpx;
  border: 1rpx solid #AA2116;
  border-radius: 24rpx;
}

.date-group {
  margin-bottom: 24rpx;
}

.date-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.date-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #D4A017;
}

.date-text {
  font-size: 26rpx;
  color: #8B7355;
  font-weight: bold;
}

.record-card {
  display: flex;
  align-items: center;
  background: #FFF8E7;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(60, 36, 21, 0.04);
}

.record-info {
  flex: 1;
}

.record-type {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #3C2415;
  margin-bottom: 8rpx;
}

.record-summary {
  display: block;
  font-size: 26rpx;
  color: #8B7355;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.record-time {
  display: block;
  font-size: 22rpx;
  color: #BBA88A;
}

.record-delete {
  padding: 16rpx;
  margin-left: 16rpx;
}

.delete-icon {
  font-size: 28rpx;
  color: #BBA88A;
}
