.page {
  min-height: 100vh;
  background: #F7F2E7;
  padding-bottom: 140rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon-text {
  font-size: 80rpx;
  color: #E8E0D0;
  margin-bottom: 24rpx;
  font-weight: bold;
}

.empty-text {
  font-size: 34rpx;
  color: #3E2723;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #A89888;
}

.history-list {
  padding: 24rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.list-count {
  font-size: 26rpx;
  color: #7D6B5D;
}

.clear-btn {
  font-size: 26rpx;
  color: #B8860B;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(201, 185, 138, 0.3);
  border-radius: 24rpx;
}

.date-group {
  margin-bottom: 24rpx;
}

.date-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.date-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #C9A96E;
}

.date-text {
  font-size: 26rpx;
  color: #7D6B5D;
  font-weight: bold;
}

.record-card {
  display: flex;
  align-items: center;
  background: #FDFAF2;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(58,58,85,0.5);
}

.record-info {
  flex: 1;
}

.record-type {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #3E2723;
  margin-bottom: 8rpx;
}

.record-summary {
  display: block;
  font-size: 26rpx;
  color: #7D6B5D;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.record-time {
  display: block;
  font-size: 22rpx;
  color: #A89888;
}

.record-delete {
  padding: 16rpx;
  margin-left: 16rpx;
}

.delete-icon {
  font-size: 28rpx;
  color: #A89888;
}
