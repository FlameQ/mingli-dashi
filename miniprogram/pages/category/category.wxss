.page {
  min-height: 100vh;
  background: #F7F3EC;
  padding-bottom: 140rpx;
}

.category-list {
  padding: 24rpx;
}

.category-group {
  margin-bottom: 32rpx;
}

.group-header {
  margin-bottom: 16rpx;
}

.group-title-wrap {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.group-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #2D2D2D;
}

.group-desc {
  font-size: 24rpx;
  color: #AAAAAA;
}

.group-line {
  height: 1rpx;
  background: linear-gradient(90deg, #E5DFD3, transparent);
}

.module-list {
  background: #FFFCF5;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(58,58,85,0.5);
}

.module-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(58,58,85,0.5);
  transition: background 0.2s;
}

.module-item:last-child {
  border-bottom: none;
}

.module-item-hover {
  background: rgba(136, 173, 166, 0.05);
}

.module-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: rgba(136, 173, 166, 0.1);
  border: 1rpx solid rgba(136, 173, 166, 0.2);
}

.module-icon-char {
  font-size: 28rpx;
  color: #4A7C8A;
  font-weight: bold;
}

.module-info {
  flex: 1;
}

.module-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.module-desc {
  display: block;
  font-size: 24rpx;
  color: #AAAAAA;
}

.module-arrow {
  font-size: 28rpx;
  color: #E5DFD3;
  margin-left: 16rpx;
}
