.page {
  min-height: 100vh;
  background: #FFFBF0;
  padding-bottom: 120rpx;
}

.category-list {
  padding: 24rpx;
}

.category-group {
  margin-bottom: 32rpx;
}

.group-header {
  margin-bottom: 16rpx;
}

.group-title-wrap {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.group-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #3C2415;
}

.group-desc {
  font-size: 24rpx;
  color: #8B7355;
}

.group-line {
  height: 2rpx;
  background: linear-gradient(90deg, #D4A017, #E8D5A3, transparent);
}

.module-list {
  background: #FFF8E7;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(60, 36, 21, 0.06);
}

.module-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(232, 213, 163, 0.4);
  transition: background 0.2s;
}

.module-item:last-child {
  border-bottom: none;
}

.module-item-hover {
  background: rgba(232, 213, 163, 0.2);
}

.module-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.module-info {
  flex: 1;
}

.module-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #3C2415;
  margin-bottom: 4rpx;
}

.module-desc {
  display: block;
  font-size: 24rpx;
  color: #8B7355;
}

.module-arrow {
  font-size: 40rpx;
  color: #BBA88A;
  margin-left: 16rpx;
}
