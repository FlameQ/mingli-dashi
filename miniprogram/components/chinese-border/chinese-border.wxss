.zen-border-wrapper {
  position: relative;
  background: rgba(37, 37, 64, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.03);
}

.corner {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border-color: rgba(136, 173, 166, 0.4);
  border-style: solid;
}

.corner-tl {
  top: 6rpx;
  left: 6rpx;
  border-width: 2rpx 0 0 2rpx;
}

.corner-tr {
  top: 6rpx;
  right: 6rpx;
  border-width: 2rpx 2rpx 0 0;
}

.corner-bl {
  bottom: 6rpx;
  left: 6rpx;
  border-width: 0 0 2rpx 2rpx;
}

.corner-br {
  bottom: 6rpx;
  right: 6rpx;
  border-width: 0 2rpx 2rpx 0;
}
