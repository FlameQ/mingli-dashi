.zen-border-wrapper {
  position: relative;
  background: #FDFAF2;
  border: 1rpx solid #E8E0D0;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.corner {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border-color: #C9A96E;
  border-style: solid;
}

.corner-tl {
  top: 6rpx;
  left: 6rpx;
  border-width: 2rpx 0 0 2rpx;
}

.corner-tr {
  top: 6rpx;
  right: 6rpx;
  border-width: 2rpx 2rpx 0 0;
}

.corner-bl {
  bottom: 6rpx;
  left: 6rpx;
  border-width: 0 0 2rpx 2rpx;
}

.corner-br {
  bottom: 6rpx;
  right: 6rpx;
  border-width: 0 2rpx 2rpx 0;
}
