.result-scroll {
  margin: 24rpx;
  background: #FDFAF2;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #E8E0D0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.scroll-header {
  padding: 32rpx 32rpx 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #D4C4A8, transparent);
  margin: 12rpx 0;
}

.scroll-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #3E2723;
  letter-spacing: 8rpx;
}

.scroll-body {
  padding: 16rpx 32rpx 32rpx;
}

.scroll-footer {
  padding: 24rpx 32rpx;
  text-align: center;
  border-top: 1rpx solid #E8E0D0;
}

.disclaimer {
  font-size: 22rpx;
  color: #A89888;
}
