.result-scroll {
  margin: 24rpx;
  background: #252540;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #3A3A55;
}

.scroll-header {
  padding: 32rpx 32rpx 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #3A3A55, transparent);
  margin: 12rpx 0;
}

.scroll-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #F0EDE0;
  letter-spacing: 8rpx;
}

.scroll-body {
  padding: 16rpx 32rpx 32rpx;
}

.scroll-footer {
  padding: 24rpx 32rpx;
  text-align: center;
  border-top: 1rpx solid #3A3A55;
}

.disclaimer {
  font-size: 22rpx;
  color: #666680;
}
