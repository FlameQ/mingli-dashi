.result-scroll {
  margin: 24rpx;
  background: rgba(37, 37, 64, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
}

.scroll-header {
  padding: 32rpx 32rpx 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(136, 173, 166, 0.3), transparent);
  margin: 12rpx 0;
}

.scroll-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #F0EDE0;
  letter-spacing: 8rpx;
}

.scroll-body {
  padding: 16rpx 32rpx 32rpx;
}

.scroll-footer {
  padding: 24rpx 32rpx;
  text-align: center;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.disclaimer {
  font-size: 22rpx;
  color: #666680;
}
