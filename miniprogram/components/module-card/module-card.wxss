.module-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 340rpx;
  padding: 32rpx 24rpx;
  background: #FDFAF2;
  border-radius: 24rpx;
  border: 1rpx solid #E8E0D0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s ease, border-color 0.2s ease;
}

.module-card-hover {
  transform: scale(0.97);
  border-color: #C9A96E;
}

.card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  background: rgba(74, 124, 138, 0.08);
  border: 1rpx solid rgba(74, 124, 138, 0.15);
}

.icon-char {
  font-size: 36rpx;
  color: #C9A96E;
  font-weight: bold;
}

.card-info {
  text-align: center;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #3E2723;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #A89888;
}
