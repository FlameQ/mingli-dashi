.module-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 340rpx;
  padding: 32rpx 24rpx;
  background: #FFF8E7;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(60, 36, 21, 0.06);
  border: 1rpx solid rgba(232, 213, 163, 0.5);
  transition: transform 0.2s ease;
}

.module-card-hover {
  transform: scale(0.97);
}

.card-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.icon-text {
  font-size: 44rpx;
}

.card-info {
  text-align: center;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #3C2415;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #8B7355;
}
