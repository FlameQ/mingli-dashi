.module-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 340rpx;
  padding: 32rpx 24rpx;
  background: #252540;
  border-radius: 24rpx;
  border: 1rpx solid #3A3A55;
  transition: transform 0.2s ease, border-color 0.2s ease;
}

.module-card-hover {
  transform: scale(0.97);
  border-color: #88ADA6;
}

.card-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  background: rgba(136, 173, 166, 0.1);
  border: 1rpx solid rgba(136, 173, 166, 0.2);
}

.icon-char {
  font-size: 36rpx;
  color: #88ADA6;
  font-weight: bold;
}

.card-info {
  text-align: center;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #F0EDE0;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #666680;
}
