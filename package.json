{
  "name": "mingli-dashi",
  "version": "1.0.0",
  "description": "命理大师 - 微信小程序",
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@vant/weapp": "^1.11.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "miniprogram-simulate": "^1.6.0",
    "miniprogram-api-typings": "^3.12.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "miniprogram/utils/**/*.js",
      "miniprogram/pages/**/*.js",
      "!**/node_modules/**"
    ]
  }
}
